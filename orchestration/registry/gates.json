{
  "$schema": "../schemas/gate-registry.v1.json",
  "version": "1.0.0",
  "description": "G0~G8 품질 게이트 정의 — 승인자/생산자/차단자/진입·통과 조건/SLA/병목 튜닝의 단일 원천",
  "gates": [
    {
      "id": "G0",
      "title": "요청 접수 · Task Graph",
      "approver": "A00",
      "producers": ["A00"],
      "verifiers": ["A75"],
      "entry": ["사용자/상위 시스템 요청 수신"],
      "exit": [
        "Task Graph 생성 (orchestration/tasks/TASK-*.json)",
        "A75 Reuse Guard 판정(REUSE/EXTEND/CREATE) 첨부",
        "판정 REUSE → 기존 컴포넌트 안내 후 파이프라인 종료"
      ],
      "slaHours": 2,
      "next": ["G1"]
    },
    {
      "id": "G1",
      "title": "기획 확정",
      "approver": "A12",
      "producers": ["A10", "A11"],
      "verifiers": [],
      "entry": ["G0 APPROVED", "Task Graph에 대상 화면/컴포넌트 명시"],
      "exit": ["Screen Spec(SCR-NNN) 작성", "체크리스트 G1 전 항목 통과", "RR-G1 APPROVED"],
      "checklist": "docs/_templates/checklists/G1.md",
      "slaHours": 4,
      "fastPath": {
        "condition": "A75 판정이 EXTEND이고 기존 Screen Spec 변경이 불필요한 경우",
        "action": "G1 생략 가능 — A00이 Task Graph에 skip 사유 기록 필수",
        "rationale": "병목 튜닝: prop 1개 추가 수준의 확장에 전체 기획 사이클 재진입은 과잉 (ADR-0001)"
      },
      "next": ["G2"]
    },
    {
      "id": "G2",
      "title": "디자인 확정",
      "approver": "A17",
      "producers": ["A13", "A14", "A15", "A16"],
      "verifiers": [],
      "entry": ["G1 APPROVED"],
      "exit": [
        "Design Spec(DS-NNN) 작성 — 전 값 토큰 참조",
        "체크리스트 G2 전 항목 통과",
        "RR-G2 APPROVED"
      ],
      "checklist": "docs/_templates/checklists/G2.md",
      "slaHours": 4,
      "fastPath": {
        "condition": "EXTEND이고 신규 시각 변경 없음 (기존 variant 조합 재사용)",
        "action": "G2 생략 가능 — 동일 기록 규칙",
        "rationale": "병목 튜닝 (ADR-0001)"
      },
      "next": ["G3"]
    },
    {
      "id": "G3",
      "title": "계약 확정 ★ (Frozen Point)",
      "approver": "A19",
      "producers": ["A18"],
      "verifiers": ["A76"],
      "entry": [
        "G2 APPROVED (또는 fastPath 기록)",
        "contracts/schemas/component.v1.json 스키마 검증 통과(자동 pre-check)"
      ],
      "exit": [
        "*.contract.json 작성 + SemVer 판정(MAJOR/MINOR/PATCH)",
        "체크리스트 G3 전 항목 통과",
        "RR-G3 APPROVED → 계약 Frozen"
      ],
      "checklist": "docs/_templates/checklists/G3.md",
      "slaHours": 4,
      "freeze": true,
      "reentryRule": "Frozen 이후 변경은 change_request → G3 재진입 + SemVer 재판정. Layer 2 작업물은 계약 버전 불일치 시 자동 무효",
      "bottleneckMitigation": [
        "자동 pre-check(validate-contract) 통과 없이는 리뷰 큐 진입 불가 — 리뷰어가 기계 검증에 시간을 쓰지 않게 함",
        "additive-only MINOR 변경은 우선순위 큐로 4h → 2h SLA 단축",
        "G3 승인 즉시 codegen 파이프라인 자동 실행 → G4~G7 생산자들이 생성물 즉시 사용 가능"
      ],
      "next": ["G4", "G5", "G6", "G7"],
      "parallelAfter": true
    },
    {
      "id": "G4",
      "title": "Token 확정",
      "approver": "A21",
      "producers": ["A20"],
      "verifiers": ["A76"],
      "entry": ["G3 APPROVED", "계약의 tokens 블록에 신규 토큰 필요 여부 명시"],
      "exit": [
        "tokens.json 갱신(DTCG)",
        "라이트/다크 페어링 완비",
        "체크리스트 G4 통과",
        "RR-G4 APPROVED"
      ],
      "checklist": "docs/_templates/checklists/G4.md",
      "slaHours": 4,
      "parallelGroup": "production",
      "orderingNote": "신규 토큰이 있는 경우 G5/G6/G7은 G4 APPROVED를 선행 조건으로 대기. 신규 토큰 0건이면 완전 병렬 (병목 튜닝, ADR-0001)",
      "next": ["contract-test-final"]
    },
    {
      "id": "G5",
      "title": "Storybook 구현",
      "approver": "A33",
      "producers": ["A30", "A31", "A32"],
      "verifiers": ["A72", "A74", "A76"],
      "entry": ["G3 APPROVED", "참조 토큰 전부 존재 (신규 토큰 필요 시 G4 APPROVED)"],
      "exit": [
        "variant × size × state 조합 Story 커버리지 100%",
        "Dark/RTL/Responsive/Long-content Story",
        "Play Function으로 events.blockedWhen 전수 검증",
        "axe critical/serious 0건",
        "RR-G5 APPROVED"
      ],
      "checklist": "docs/_templates/checklists/G5.md",
      "blockedBy": [
        {
          "agent": "A72",
          "condition": "axe critical/serious ≥ 1"
        },
        {
          "agent": "A74",
          "condition": "Contract ↔ Storybook 불일치 ≥ 1"
        }
      ],
      "slaHours": 4,
      "parallelGroup": "production",
      "next": ["contract-test-final"]
    },
    {
      "id": "G6",
      "title": "React 구현",
      "approver": "A42",
      "producers": ["A40", "A41"],
      "verifiers": ["A72", "A73", "A74", "A76"],
      "entry": ["G3 APPROVED", "packages/ui/generated 타입 생성 완료"],
      "exit": [
        "계약 생성 타입 사용 (수동 타입 선언 0건)",
        "하드코딩 값 0건 · 레이어 의존 방향 준수",
        "계약의 모든 상태 렌더 테스트",
        "Performance Budget 통과",
        "RR-G6 APPROVED"
      ],
      "checklist": "docs/_templates/checklists/G6.md",
      "blockedBy": [
        {
          "agent": "A72",
          "condition": "axe critical/serious ≥ 1"
        },
        {
          "agent": "A73",
          "condition": "Budget 초과 (gzip +2KB/컴포넌트)"
        },
        {
          "agent": "A74",
          "condition": "Contract ↔ React 불일치 ≥ 1"
        }
      ],
      "slaHours": 4,
      "parallelGroup": "production",
      "next": ["contract-test-final"]
    },
    {
      "id": "G7",
      "title": "Figma 동기화",
      "approver": "A56",
      "producers": ["A50", "A51", "A52", "A53", "A54", "A55"],
      "verifiers": ["A70", "A74", "A76"],
      "entry": ["G3 APPROVED", "플러그인용 figma.json 생성 완료 (codegen)"],
      "exit": [
        "Variable 바인딩률 100% (Detach 0)",
        "Component Set 구조 = 계약 variant",
        "VRT diff ≤ 0.1%",
        "RR-G7 APPROVED"
      ],
      "checklist": "docs/_templates/checklists/G7.md",
      "blockedBy": [
        {
          "agent": "A70",
          "condition": "pixel diff > 0.1%"
        },
        {
          "agent": "A74",
          "condition": "Contract ↔ Figma 불일치 ≥ 1"
        }
      ],
      "slaHours": 8,
      "parallelGroup": "production",
      "next": ["contract-test-final"]
    },
    {
      "id": "contract-test-final",
      "title": "4자 일치 최종 검증 (게이트 아님 — 합류 배리어)",
      "approver": "A74",
      "producers": [],
      "verifiers": ["A74"],
      "entry": ["G4, G5, G6, G7 전부 APPROVED"],
      "exit": ["Contract ↔ React ↔ Storybook ↔ Figma 4자 일치 100%"],
      "slaHours": 1,
      "next": ["G8"]
    },
    {
      "id": "G8",
      "title": "릴리스",
      "approver": "A03",
      "producers": ["A60", "A03"],
      "verifiers": ["A61"],
      "entry": ["4자 일치 최종 검증 통과", "TDS 문서 갱신"],
      "exit": [
        "SemVer 확정 · CHANGELOG 갱신 (Breaking 명시)",
        "MAJOR인 경우 Migration Guide 존재",
        "RR-G8 APPROVED (A61) + 릴리스 승인 (A03)",
        "이후 A71 Design Drift 상시 감시 루프 진입"
      ],
      "checklist": "docs/_templates/checklists/G8.md",
      "slaHours": 8,
      "next": []
    },
    {
      "id": "G9",
      "title": "명세 확정 — 기능 명세 + 백엔드 명세",
      "approver": "A64",
      "producers": ["A62", "A63"],
      "verifiers": [],
      "entry": [
        "화면이 컨펌됨 (사용자 또는 A00 승인) — 컨펌 전 화면은 명세 대상이 아니다",
        "해당 화면의 SCR(docs/plan/ui/)과 구현(apps/**)이 존재"
      ],
      "exit": [
        "기능 명세서 FS-NNN 작성 — specs/<라우트 경로>/FS-NNN-*.md, 화면 요소 전수 넘버링(FS-NNN-EL-nnn)",
        "백엔드 기능 명세 BE-NNN 작성 — specs/<라우트 경로>/BE-NNN-*.md, FS 요소 번호 역참조",
        "체크리스트 G9 전 항목 통과",
        "RR-G9 APPROVED (specs/_review/)"
      ],
      "checklist": "docs/_templates/checklists/G9.md",
      "slaHours": 8,
      "orderingNote": "G9 는 화면 컨펌 이후에 돈다. G6(React 구현) 완료가 선행 조건이지만 G8(릴리스)와는 병렬 가능 — 백엔드 개발자가 명세를 먼저 받아야 병목이 안 생긴다 (ADR-0004)",
      "bottleneckMitigation": [
        "A62(FS) 완료 즉시 A63(BE)이 착수한다 — FS 전체 승인을 기다리지 않고 요소 단위로 흘린다",
        "BE 명세는 프론트의 data-source 어댑터 시그니처에서 출발한다 — 이미 뚫린 연동 지점이 초안이므로 백지에서 시작하지 않는다"
      ],
      "next": []
    }
  ],
  "stateMachine": {
    "states": ["DRAFT", "IN_REVIEW", "APPROVED", "REWORK", "ESCALATED", "SKIPPED"],
    "transitions": [
      {
        "from": "DRAFT",
        "event": "submit",
        "to": "IN_REVIEW"
      },
      {
        "from": "DRAFT",
        "event": "skip",
        "to": "SKIPPED",
        "guard": "gates.json fastPath 조건 충족 + Task Graph에 skipReason 기록 (A00)"
      },
      {
        "from": "IN_REVIEW",
        "event": "approve",
        "to": "APPROVED"
      },
      {
        "from": "IN_REVIEW",
        "event": "changes_requested",
        "to": "REWORK"
      },
      {
        "from": "IN_REVIEW",
        "event": "blocked",
        "to": "ESCALATED"
      },
      {
        "from": "REWORK",
        "event": "resubmit",
        "to": "IN_REVIEW",
        "guard": "reworkCount <= 2"
      },
      {
        "from": "REWORK",
        "event": "rework_limit_exceeded",
        "to": "ESCALATED",
        "guard": "reworkCount == 3"
      }
    ],
    "escalationChain": ["A01", "A00", "human"],
    "loopPrevention": "동일 지적사항 3회 반복 시 자동 에스컬레이션. Reviewer는 지적만 하고 직접 수정하지 않는다 (P1)"
  },
  "slo": {
    "contractImplementationMatch": {
      "target": "100%",
      "owner": "A74"
    },
    "storybookFigmaVisualDiff": {
      "target": "<= 0.1%",
      "owner": "A70"
    },
    "hardcodedValues": {
      "target": "0",
      "owner": "A71"
    },
    "componentDuplicationRate": {
      "target": "<= 3%",
      "owner": "A75"
    },
    "a11yCriticalViolations": {
      "target": "0",
      "owner": "A72"
    },
    "storyCombinationCoverage": {
      "target": "100%",
      "owner": "A33"
    },
    "gateFirstPassRate": {
      "target": ">= 70%",
      "owner": "A00"
    },
    "avgRejectionCount": {
      "target": "<= 1.3",
      "owner": "A00"
    },
    "driftFixLeadTime": {
      "target": "<= 24h",
      "owner": "A71"
    },
    "newComponentLeadTime": {
      "target": "<= 3d (G0→G8)",
      "owner": "A00"
    }
  }
}
