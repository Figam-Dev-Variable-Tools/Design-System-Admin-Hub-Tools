{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tds.internal/schemas/review-report.v1.json",
  "title": "TDS Review Report (D5) Frontmatter v1",
  "description": "모든 Reviewer의 검수 리포트(RR-<gate>-<id>.md) YAML frontmatter 규격. 본문은 docs/_templates/D5-review-report.md 템플릿을 따른다.",
  "type": "object",
  "required": ["gate", "target", "reviewer", "producer", "result", "date", "checklist"],
  "additionalProperties": false,
  "properties": {
    "gate": { "enum": ["G0", "G1", "G2", "G3", "G4", "G5", "G6", "G7", "G8", "G9"] },
    "target": {
      "type": "string",
      "pattern": "^[A-Za-z0-9-]+@(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "reviewer": { "$ref": "#/$defs/agentId" },
    "producer": { "$ref": "#/$defs/agentId" },
    "result": { "enum": ["APPROVED", "CHANGES_REQUESTED", "BLOCKED"] },
    "severity": {
      "enum": ["blocker", "major", "minor", "nit", "none"],
      "description": "최고 심각도. blocker>=1 → BLOCKED, major>=1 → CHANGES_REQUESTED, minor/nit만 → APPROVED + 후속 티켓"
    },
    "date": { "type": "string", "format": "date" },
    "reworkCount": { "type": "integer", "minimum": 0, "maximum": 3 },
    "slaHours": { "type": "number" },
    "checklist": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["item", "pass"],
        "additionalProperties": false,
        "properties": {
          "item": { "type": "string" },
          "pass": { "type": "boolean" },
          "evidence": {
            "type": "string",
            "description": "자동화 스크립트 출력 경로 또는 재현 방법"
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "location", "description", "requiredAction"],
        "additionalProperties": false,
        "properties": {
          "severity": { "enum": ["blocker", "major", "minor", "nit"] },
          "location": { "type": "string" },
          "description": { "type": "string" },
          "requiredAction": { "type": "string" },
          "reproduction": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "agentId": { "type": "string", "pattern": "^A\\d{2}$" }
  }
}
