{
  "$schema": "https://tds.internal/schemas/component.v1.json",
  "name": "Tabs",
  "version": "1.0.0",
  "level": "molecule",
  "category": "Navigation",
  "taxonomyItem": "tabs",
  "status": "beta",
  "description": "하단 밑줄형 탭 목록. 선택된 탭만 액션 컬러 밑줄을 갖고, 비선택 탭도 동일 두께의 투명 밑줄을 둬 전환 시 라벨이 밀리지 않는다. 탭 패널은 이 컴포넌트가 렌더하지 않는다 — 패널을 소유하지 않으므로 탭→패널 aria-controls 를 두지 않고(지킬 수 없는 참조라 axe aria-valid-attr-value 를 유발), 패널→탭 연결은 조립부가 패널에 aria-labelledby={tabId(id)} 로 건다. 도메인 중립: 탭 항목은 items prop 으로 주입한다 (ADR-0003). 출처 구현: apps/admin/src/pages/dashboard/components/TabBar.tsx",
  "owner": {
    "code": "component-eng",
    "design": "ui-design",
    "figma": "figma-eng"
  },
  "props": {
    "value": {
      "type": "string",
      "required": true,
      "description": "선택된 탭의 id. items[].id 중 하나여야 한다"
    },
    "items": {
      "type": "array",
      "itemShape": "{ id: string; label: string }",
      "required": true,
      "description": "탭 목록. 데이터 prop — Figma Component Property 대응 없음 (ADR-0003)"
    },
    "ariaLabel": {
      "type": "string",
      "required": true,
      "description": "tablist 의 접근 가능한 이름 (예: '업무 영역')"
    }
  },
  "events": {
    "onChange": {
      "payload": "string",
      "description": "선택된 탭의 id 를 전달"
    }
  },
  "states": ["default", "hover", "focus-visible", "selected"],
  "tokens": {
    "listBorder": "color.border.default",
    "indicatorSelected": "color.action.primary.default",
    "text": "color.text.muted",
    "textSelected": "color.text.default",
    "typography": "typography.label.md",
    "paddingTop": "space.2",
    "paddingBottom": "space.3",
    "gap": "space.5",
    "focusRing": "color.border.focus",
    "transitionDuration": "motion.duration.fast",
    "transitionEasing": "motion.easing.standard"
  },
  "a11y": {
    "role": "tablist",
    "keyboard": ["Tab", "ArrowLeft", "ArrowRight", "Home", "End"],
    "focusVisible": true,
    "aria": {
      "aria-label": "ariaLabel prop — tablist 의 이름",
      "aria-selected": "각 탭(role=tab) — value 와 일치하면 true"
    },
    "contrastMin": 4.5
  },
  "responsive": {
    "breakpoints": ["sm", "md", "lg"],
    "behavior": "fluid"
  },
  "compat": {
    "breakingSince": null,
    "deprecatedProps": []
  },
  "dependencies": [],
  "anatomy": {
    "kind": "frame",
    "name": "Tabs",
    "layout": "HORIZONTAL",
    "align": "MIN",
    "styles": {
      "stroke": "listBorder",
      "gap": "gap"
    },
    "children": [
      {
        "kind": "frame",
        "name": "Tab",
        "layout": "VERTICAL",
        "align": "CENTER",
        "repeat": 4,
        "styles": {
          "padY": "paddingTop"
        },
        "children": [
          {
            "kind": "text",
            "name": "Label",
            "text": "대시보드",
            "styles": {
              "color": "text",
              "typography": "typography"
            },
            "samples": ["대시보드", "주문", "회원", "설정"]
          },
          {
            "kind": "line",
            "name": "Indicator",
            "fixedHeight": 2,
            "styles": {
              "stroke": "indicatorSelected"
            }
          }
        ]
      }
    ]
  }
}
