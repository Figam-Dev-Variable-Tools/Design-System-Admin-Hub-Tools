{
  "name": "@tds/flow-render",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "플로우 차트 렌더 생성기 — docs/flow/mmd/**/*.mmd(정본)에서 docs/flow/html/**/*.html 을 만든다. 브라우저 없이 도는 결정론적 생성기 + 신선도 검사(--check)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "render": "tsx src/index.ts",
    "check": "tsx src/index.ts --check",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "mermaid": "^11.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
