%% 알림 설정 · /settings/notifications
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /settings/notifications"]) --> SCOPE["이 화면이 하는 일은 하나다 — 종류마다 **받을지 말지**<br/>종류를 만들거나 문구를 고치는 자리가 아니다<br/>NOTIFICATION_KINDS 8종이 정본(shared/notifications/catalog.ts)"]
  SCOPE --> Q["useQuery notificationPrefsKey ['notifications','preferences']<br/>notificationPrefsStore.fetch(signal)<br/>**문서의 정본은 알림 층에 있다** — 이 화면은 자기 저장소를 갖지 않는다"]

  Q --> ST{"조회 상태"}
  ST -->|"isFetching && data===undefined"| SKEL["Skeleton (aria-busy · '알림 설정을 불러오는 중')"]
  ST -->|"error !== null"| ERR1["Alert danger '알림 설정을 불러오지 못했습니다. 아래는 기본값(전부 받음)입니다.'<br/>+ [다시 시도] → refetch"]
  ST -->|"성공"| NORM["normalizePrefs(data.kinds) — 저장값 방어<br/>알 수 없는 키는 버리고 **빠진 키는 켜짐으로** 채운다<br/>꺼짐으로 채우면 새 종류가 아무에게도 도착하지 않고 그 사실을 아무도 모른다<br/>(소음은 운영자가 끌 수 있지만 침묵은 알아챌 방법이 없다)"]
  ERR1 --> NORM
  SKEL --> NORM

  NORM --> BASE["server = normalizePrefs(...) · serverKey = keyOf(server)<br/>baseline !== serverKey 면 렌더 중 동기화로 draft 를 다시 시작한다<br/>(useEffect 없이 — 재조회가 초안을 조용히 덮지 않게)"]
  BASE --> LIST["종류 행 8개 — 라벨 · 설명 · '이동 위치: {leafPath}'<br/>severity='warning' 이면 StatusBadge '기한 경고'<br/>ToggleSwitch onLabel='받음' / offLabel='받지 않음'"]

  LIST --> OFFN{"offCount = 꺼진 종류 수"}
  OFFN -->|"&gt; 0"| OFFW["Alert warning 'N개 종류를 받지 않도록 설정했습니다.<br/>그 사건들은 목록을 직접 새로고침해야 알 수 있습니다.'"]
  OFFN -->|"0"| OFFOK["경고 없음"]

  LIST --> PERM{"canUpdate (useRouteWritePermissions)"}
  PERM -->|"false"| RO["Alert info '조회 권한만 있어 알림 설정을 변경할 수 없습니다.'<br/>토글 disabled + **저장 컨트롤 자체를 렌더하지 않는다** (EXC-03)"]
  PERM -->|"true"| EDIT["토글 → setDraft — dirty = keyOf(draft) !== serverKey (파생값)"]

  EDIT --> SAVE{"저장 버튼 — disabled = !dirty || isPending || loading"}
  SAVE -->|"클릭"| MUT["save.mutate(draft) → notificationPrefsStore.save({kinds})<br/>TODO(backend): GET/PUT /api/notifications/preferences"]
  MUT --> MR{"결과"}
  MR -->|"성공"| MOK["invalidate notificationPrefsKey<br/>toast '알림 설정을 저장했습니다.'"]
  MR -->|"실패"| MER["toast '알림 설정을 저장하지 못했습니다. 잠시 후 다시 시도해 주세요.'"]
  MOK --> Q
  MER --> LIST

  %% ── 이 설정이 실제로 걸리는 자리 ──
  Q -.->|"헤더의 벨이 읽는다"| BELL["useNotifications — 목록에 넣을지를 **여기서** 가른다"]
  BELL --> G1{"prefs[notification.kind]"}
  G1 -->|"false"| G1X["**끈 알림은 만들어지지도 않는다**<br/>감추기만 하면 안읽음 수는 계속 오르고<br/>벨에 점이 떠 있는데 열면 아무것도 없는 상태가 된다"]
  G1 -->|"true"| G2{"notificationResourceOf(kind) → navPageResourceId(leafPath)<br/>can(resourceId, 'read')"}
  G2 -->|"리소스를 못 풀거나 권한 없음"| G2X["**버린다 (fail-closed)**<br/>'새 주문이 접수되었습니다 · 3건' 한 줄은 주문 목록을 볼 수 없는 역할에게<br/>주문의 존재와 요약을 흘린다 — 알림이 권한 우회로가 되면 안 된다<br/>**권한이 언제나 먼저다**: 여기서 켜 두어도 조회 권한이 없으면 오지 않는다"]
  G2 -->|"통과"| G3{"notificationPathOf(kind, targetId)"}
  G3 -->|"null"| G3X["버린다"]
  G3 -->|"targetId 가 빈 값"| G3L["잎 경로(목록)로 보낸다 — '없는 상세' 로 보내지 않는다"]
  G3 -->|"targetId 있음"| G3D["`${leafPath}/${targetId}`"]
  G3L --> ROWS
  G3D --> ROWS["NotificationRow{...notification, path, read}<br/>read = readIds.has(id) — Zustand useNotificationReadState<br/>**읽음/안읽음 두 상태뿐이다**(보관·삭제 축이 없다)"]
  ROWS --> UNREAD["unreadCount = rows.filter(!read).length — **파생값이다**<br/>저장하면 배지는 3인데 열면 5개가 안읽음인 날이 온다"]
  ROWS --> MARK{"읽음 처리"}
  MARK -->|"markRead(id)"| MK1["그 한 건만"]
  MARK -->|"markAllRead()"| MK2["**보이는 것만** 읽음으로 만든다<br/>권한이 없어 목록에 없던 알림까지 읽음으로 바꾸지 않는다"]

  %% ── 카탈로그의 규약 ──
  SCOPE -.->|"경로는 nav 에서 파생된다"| CAT["leafPath 는 **사이드바 잎 하나**를 가리킨다<br/>알림이 자기 경로를 통째로 들면 메뉴가 옮겨진 날 알림만 옛 주소로 간다<br/>잎 경로가 곧 권한 리소스(`page:{to}`)라 '알림을 볼 수 있는가' 와<br/>'그 화면을 볼 수 있는가' 가 **같은 질문**이 된다<br/>notifications.test.ts 가 모든 잎이 nav 에 실재하는지 전수로 확인한다"]

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class ST,OFFN,PERM,SAVE,MR,G1,G2,G3,MARK gate
  class ERR1,OFFW,RO,MER,G1X,G2X,G3X err
  class OFFOK,MOK,ROWS ok
