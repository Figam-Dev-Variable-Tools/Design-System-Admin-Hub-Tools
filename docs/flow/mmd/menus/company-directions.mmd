%% 오시는 길 · /company/directions
%% 주소는 검색으로 고르고, 지도는 카카오 지도 SDK 로 **실제로** 그린다
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /company/directions"]) --> Q["useDocumentQuery<br/>directionsStore.fetch"]
  Q --> ST{"조회 상태"}
  ST -->|"로딩"| LD["DocumentFormShell<br/>스켈레톤 4행"]
  ST -->|"실패"| LE["danger 배너<br/>'내용을 불러오지 못했습니다'"]
  ST -->|"성공"| FM["단일 문서 폼 reset(data)<br/>목록 없음"]
  LD --> ST
  LE --> RT["다시 시도 refetch"]
  RT --> Q

  FM --> ADDR["**주소 칸은 readOnly 다 — 직접 타이핑하지 않는다**<br/>자유 입력을 함께 열어 두면 사람이 주소를 고친 뒤 좌표를 그대로 두는 상태가 생기고,<br/>그때 홈페이지의 주소와 지도의 핀이 다른 곳을 가리킨다 — 틀렸다는 표시 없이<br/>[a11y] 클릭에만 걸지 않았다: readOnly 입력도 포커스를 받으므로 Enter·Space 로도 열리고,<br/>옆의 '주소 검색' 버튼이 스크린리더에 보이는 정식 트리거다<br/>(Enter 가 폼을 제출해 버리지 않도록 preventDefault)"]

  ADDR --> MODAL{"AddressSearchModal — 다음(카카오) 우편번호 서비스<br/>**앱 키가 필요 없다** · DS Modal 안에 embed 로 심는다"}
  MODAL -->|"왜 open() 팝업이 아닌가"| MWHY["팝업은 차단기에 막히면 **아무 일도 일어나지 않는 버튼**이 되고<br/>그 실패를 우리가 관측할 방법이 없다<br/>임베드는 우리 DOM 안에서 벌어지므로 로딩·실패를 우리가 그릴 수 있고<br/>Esc·포커스 복귀 같은 약속도 모달 하나가 일관되게 지킨다"]
  MODAL -->|"로딩"| MLOAD["'주소 검색을 불러오는 중입니다…' (aria-busy)"]
  MODAL -->|"unreachable"| MERR["'주소 검색 서비스를 불러오지 못했습니다. 네트워크 연결이 끊겼거나<br/>브라우저 확장 프로그램이 차단했을 수 있습니다.' + 다시 시도<br/>**노드 자체는 언마운트하지 않는다** — 지우면 '다시 시도' 가 심을 자리가 사라진다"]
  MODAL -->|"선택"| PICK["selectedAddressOf(address) → 주소 칸<br/>건물명은 **상세주소가 비어 있을 때만** 제안한다 —<br/>이미 '8층 802호' 라고 적어 둔 사람의 입력을 검색 한 번으로 덮으면 되돌릴 방법이 없다"]

  PICK --> GEO{"지오코딩 — mapAdapter().geocode(주소)<br/>**우편번호 서비스는 좌표를 주지 않는다** →<br/>지도 SDK 의 services 라이브러리(Geocoder)로 변환한다"}
  GEO -->|"running"| G0["'검색한 주소의 좌표를 확인하는 중입니다…' (aria-busy)"]
  GEO -->|"filled"| G1["위도·경도를 채운다(소수점 6자리 ≈ 0.1m)<br/>'검색한 주소의 좌표로 위도·경도를 채웠습니다.<br/>실제 출입구와 다르면 직접 고칠 수 있습니다.'"]
  GEO -->|"not-found · ZERO_RESULT"| G2["warning '이 주소의 좌표를 찾지 못했습니다.<br/>아래 위도·경도를 직접 입력해 주세요.'"]
  GEO -->|"missing-key"| G3["warning '지도 앱 키가 등록되지 않아 좌표를 자동으로 채우지 못했습니다.<br/>아래 위도·경도를 직접 입력해 주세요.'"]
  GEO -->|"unreachable"| G4["warning '좌표를 조회하지 못했습니다. 네트워크 연결이 끊겼거나<br/>브라우저 확장 프로그램이 차단했을 수 있습니다.'<br/>**둘을 함께 말하는 이유**: 브라우저는 스크립트가 못 온 사정을 알려주지 않는다<br/>(둘 다 error 이벤트 하나로 온다). 하나만 골라 적으면 절반의 경우에 틀린 안내가 되고<br/>운영자는 멀쩡한 회선을 의심하며 시간을 쓴다"]
  GEO -->|"rejected"| G5["warning '카카오 지도가 앱 키를 거절해 좌표를 조회하지 못했습니다.<br/>키 값과 등록된 사이트 도메인을 확인해 주세요.'"]

  G1 --> COORD
  G2 --> COORD
  G3 --> COORD
  G4 --> COORD
  G5 --> COORD

  COORD["**좌표 칸은 남겼다 — 셋 때문이다**<br/>① 앱 키가 아직 등록되지 않았다(지오코더는 지도 SDK 의 일부다)<br/>② 지오코더가 그 주소의 좌표를 모른다(신축 도로명 등 · ZERO_RESULT)<br/>③ 지오코딩이 주는 점은 '주소의 대표점' 이라 **실제 출입구·주차장 입구와 다를 수 있다**<br/>칸을 없애면 ①②에서 저장 자체가 불가능하고 ③에서 핀을 옮길 방법이 사라진다<br/><br/>**어긋났을 때의 진실은 폼 값이다** — 검색 결과와 손입력이 다르면 **나중에 쓴 쪽**이 남는다<br/>지도는 '지금 폼에 적힌 좌표' 만 그린다(검색 결과를 따로 기억하지 않는다)<br/>즉 화면에 보이는 지도 = 저장될 좌표. 둘이 다를 수 있는 상태가 **아예 없다**"]

  COORD --> MP{"MapPreview — coordinatesOf(위도, 경도)<br/>비었거나 숫자가 아니거나 범위를 벗어나면 **null**<br/>0,0(기니만) 같은 기본값으로 떨어뜨리지 않는다 —<br/>지도는 성공적으로 그려지고 운영자는 자기 회사가 바다 한가운데 있는 것을 본다<br/>그건 오류가 아니라 **완결된 거짓말**이다"}
  MP -->|"mapProviderKey() === null"| MK["info 배너 '지도를 표시하려면 카카오 지도 JavaScript 앱 키가 필요합니다.'<br/>+ API Key 설정 링크 · '키가 없어도 주소 검색과 저장은 그대로 동작합니다.'<br/>회색 상자에 '지도' 라고 써 두지 않는다 — 그것이 예전과 똑같은 거짓이다<br/>⚠ 이음매(registerMapProviderKeyLookup)는 **아직 배선되지 않았다** —<br/>API Key 카탈로그에 '카카오 지도' 항목이 없다"]
  MP -->|"coords === null"| MN["'위도·경도가 채워지면 이 자리에 지도가 표시됩니다.'"]
  MP -->|"로딩"| ML["'지도를 불러오는 중입니다…' (aria-busy)<br/>로딩과 실패를 한 빈 상자로 뭉개면<br/>운영자는 기다려야 할지 다시 눌러야 할지 알 수 없다"]
  MP -->|"failed"| MF["danger 배너 + '다시 시도' — 원인별로 문장이 다르다<br/>missing-key / unreachable(네트워크 또는 확장 차단) / rejected(키·도메인)<br/>**노드는 항상 남긴다** — 지우면 '다시 시도' 가 지도를 심을 자리가 없어진다"]
  MP -->|"ready"| MOK["**실제 지도** + 좌표 텍스트<br/>지도는 캔버스라 스크린리더가 읽지 못한다 — 좌표를 글자로도 남긴다<br/>좌표만 바뀌면 지도를 다시 만들지 않고 setCenter 로 중심을 옮긴다<br/>(매번 다시 만들면 위도 한 글자를 고칠 때마다 화면이 깜빡인다)"]

  MOK --> DR["isDirty = true · 저장 버튼 활성"]
  MK --> DR
  MN --> DR
  MF --> DR
  DR --> SB["저장 제출 handleSubmit"]

  SB --> VA{"zod 검증 · directionsSchema"}
  VA -->|"주소 공백·길이 초과"| VAD["인라인 오류 · 저장 중단"]
  VA -->|"좌표 비숫자 또는 범위 밖<br/>위도 ±90 · 경도 ±180"| VC["'숫자여야 합니다' · '범위여야 합니다'<br/>문서는 **문자열**로 든다 — 입력 중간 상태('37.', '-')는 숫자가 아니고<br/>숫자로 강제하면 타이핑이 튄다. 숫자 규칙은 저장 직전 zod 가 지킨다"]
  VA -->|"통과"| MU["useSaveDocument.mutate · AbortController signal"]
  VAD --> COORD
  VC --> COORD

  MU --> MR{"저장 결과"}
  MR -->|"성공"| OK["reset(values) · dirty 해제<br/>'오시는 길을 저장했습니다' 토스트"]
  MR -->|"실패"| SE["카드 내 danger 배너 '저장하지 못했습니다'"]
  MR -->|"취소 isAbort"| AB["무시 · 배너 없음"]
  OK --> FM
  SE --> DR
  AB --> DR

  DR --> LV{"저장 없이 화면 이탈"}
  LV -->|"확인"| DIS["변경 폐기 · 이동"]
  LV -->|"취소"| DR

  KEYS["**키가 필요한 곳과 필요 없는 곳이 다르다**<br/>주소 검색(다음 우편번호) — **앱 키 불필요**. 그래서 키가 없어도 주소는 고를 수 있다<br/>지도 · 좌표 자동 채움 — **JavaScript 앱 키 + 사이트 도메인 등록이 필수**<br/>(카카오는 이 키를 비밀 유지가 아니라 **도메인 허용목록**으로 지킨다 —<br/>스크립트 URL 의 쿼리스트링에 실려 나가므로 숨길 수 없는 공개 식별자다)<br/>공백만 든 값도 null 로 수렴시킨다: '등록됐다' 로 보이면서 SDK 는 거절하는<br/>조합이 가장 진단하기 어렵다"]
  KEYS -.-> MP
  KEYS -.-> MODAL

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d
  class ST,MODAL,GEO,MP,VA,MR,LV gate
  class LE,MERR,G2,G3,G4,G5,MK,MF,VAD,VC,SE err
