%% 페이지 관리 · /content/pages
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 · /content/pages"]) --> URL["useListState (IA-13 URL 쿼리스트링)<br/>FILTER_DEFAULTS status='all' · q<br/>parseFilter(filters['status'], STATUS_FILTER_VALUES, 'all')<br/>all|draft|scheduled|published|archived"]
  URL --> Q["useCrudList resource 'site-pages'<br/>sitePageAdapter (createStoreAdapter)"]
  Q --> ST{"목록 조회 상태"}
  ST -->|"isPending"| LOAD["CrudListShell 스켈레톤"]
  ST -->|"isError · ?fail=list"| ERRL["인라인 Alert 배너 + 다시 시도"]
  ST -->|"visibleItems.length = 0"| EMPTY["Empty label='페이지'<br/>hasQuery → 검색어 지우기 · hasActiveFilters → 필터 초기화<br/>createAction (canCreate 일 때만)"]
  ST -->|"성공"| LIST["CrudListShell<br/>제목 + /slug · 상태 · 공개 일시 · 옛 주소 · 최근 수정<br/>정렬 sortSitePages — updatedAt 내림차순<br/>rowTarget kind='edit' → /content/pages/:id/edit"]
  ERRL -->|"재시도"| Q

  LIST --> DERIV{"**상태 열은 저장값이 아니다**<br/>sitePageStatus = effectivePublishStatus(page, now)<br/>shared/domain/publish-schedule"}
  DERIV -->|"status !== 'published'"| D1["draft · archived 를 그대로 — publishAt 을 보지 않는다<br/>(보관한 글이 예약 시각에 되살아나면 사고다)"]
  DERIV -->|"publishAt = '' 또는 형식 아님"| D2["published — '' 은 '즉시 공개' 다"]
  DERIV -->|"publishAt &gt; now"| D3["**scheduled** — 저장되지 않는 파생 상태<br/>시각이 지나면 새로고침만으로 발행이 된다"]
  D1 --> BADGE
  D2 --> BADGE
  D3 --> BADGE["StatusBadge PUBLISH_STATUS_TONE/LABEL<br/>draft 초안 · scheduled 예약 · published 발행 · archived 보관<br/>now 를 한 번만 만들어 전 행이 같은 시각으로 판정된다"]

  LIST --> F{"조회 조건 변경"}
  F -->|"제목·주소 검색 · 디바운스"| SETQ
  F -->|"상태 SelectField"| SETQ
  SETQ["URL 쿼리 갱신 · 기본값(all)은 URL 에서 제거<br/>filterSitePages(items, status, keyword, now)"] --> Q

  LIST --> ACT{"액션 선택"}
  ACT -->|"페이지 등록 · canCreate"| NEW["/content/pages/new"]
  ACT -->|"행 클릭 · 연필"| EDIT["/content/pages/:id/edit"]
  ACT -->|"휴지통 · SelectionBar"| DEL["CrudListShell 삭제 · 일괄 삭제<br/>ConfirmDialog → useCrudDelete → invalidate list"]
  DEL --> Q

  %% ── 등록 · 수정 폼 ──
  NEW --> FORM
  EDIT --> FORM
  FORM["SitePageFormPage · useCrudForm + FormPageShell<br/>제목 · 주소(슬러그) · 상태 · 공개 일시 · 본문<br/>STORED_STATUS_OPTIONS — **예약은 고를 수 없다**(시각이 만든다)"] --> V{"zodResolver(sitePageSchema)<br/>체크 순서 = 에러 우선순위"}
  V -->|"제목 공백 · TITLE_MAX_LENGTH 100 초과"| VE
  V -->|"슬러그 공백 SLUG_REQUIRED"| VE
  V -->|"SLUG_MAX_LENGTH 60 초과 SLUG_TOO_LONG"| VE
  V -->|"SLUG_RE 불일치 SLUG_FORMAT<br/>소문자·숫자·하이픈"| VE
  V -->|"RESERVED_SLUGS 충돌 SLUG_RESERVED<br/>admin·api·preview·assets·static"| VE
  V -->|"본문 공백 · BODY_MAX_LENGTH 20000 초과"| VE
  V -->|"publishAt 이 isPublishAtFormat 아님"| VE2["PUBLISH_AT_INVALID<br/>'2026-02-31' 처럼 굴러가는 날짜를 되읽어 거른다"]
  V -->|"publishAt 이 있는데 status !== 'published'"| VE3["'공개 일시는 발행 상태에서만 지정할 수 있습니다.'"]
  VE["필드 인라인 에러 (첫 이슈만) · 제출 차단"] --> FORM
  VE2 --> FORM
  VE3 --> FORM

  FORM --> WARN{"slugChangeWarning(loaded, slug)<br/>**막지 않는다 — 사실을 통지한다**"}
  WARN -->|"firstPublishedAt = '' (한 번도 공개된 적 없음)"| WN["null — 경고 없음"]
  WARN -->|"입력한 슬러그 = 지금 슬러그"| WN
  WARN -->|"공개된 적 있는 주소를 바꾸는 중"| WY["Alert warning SLUG_CHANGE_WARNING<br/>'이미 공개된 주소입니다. 바꾸면 기존 링크·북마크·검색 결과가<br/>모두 끊깁니다. 옛 주소는 되돌릴 수 있도록 보관합니다.'<br/>+ 보관 중인 옛 주소 목록 hint"]
  WY --> FORM
  WN --> FORM

  V -->|"통과"| BUILD["buildInput(values, loadedRef.current)<br/>firstPublishedAt — 과거의 사실이라 폼 값에서 되살릴 수 없다<br/>previousSlugs = withRetiredSlug(옛 슬러그를 앞에 · 멱등)<br/>versions = [snapshotOf(… '내용 수정'), …기존]"]
  BUILD --> MUT["createSitePage / updateSitePage<br/>saving = isPending · 버튼 잠금"]
  MUT --> SF{"저장 경로의 마지막 문<br/>assertSlugFree(slug, selfId) — 폼은 자기 입력만 안다"}
  SF -->|"다른 페이지가 쓰는 주소"| SF1["HttpError 422 violations[field='slug']<br/>slugTakenMessage — **슬러그 칸에 인라인** (EXC-07)"]
  SF -->|"옛 주소와 충돌"| SF2["slugRetiredMessage<br/>남겨 둔 리다이렉트 근거를 새 페이지가 빼앗지 못하게"]
  SF -->|"통과"| MR{"mutation 결과"}
  SF1 --> FORM
  SF2 --> FORM
  MR -->|"성공"| OKS["토스트 성공 · invalidate lists · detail<br/>등록이면 저장소가 v1('최초 등록')을 찍는다"]
  MR -->|"실패 · ?fail=save"| ERRS["폼 상단 serverError 배너 · 재제출 = 재시도"]
  ERRS --> FORM
  OKS --> BACK["복귀 · navigate(replace: true) → 목록"]
  BACK --> Q

  %% ── 폼 제출이 아닌 두 조작 ──
  FORM --> PV["초안 미리보기 (isEdit 일 때만 · type='button')<br/>useIssuePreviewToken → issuePreviewToken(id)<br/>previewToken = crypto.randomUUID()"]
  PV --> PVR{"결과"}
  PVR -->|"성공"| PVOK["toast '미리보기 링크를 만들었습니다.'<br/>previewPath = /preview/{slug}?token={previewToken}<br/>**주소를 만들어 보관만 한다** — 여는 것은 홈페이지·백엔드의 일<br/>TODO(backend): GET /preview/:slug?token="]
  PVR -->|"isAbort"| PVAB["[EXC-09] 취소는 실패가 아니다 — 무시"]
  PVR -->|"실패"| PVER["toast '미리보기 링크를 만들지 못했습니다…'"]
  PVOK --> FORM
  PVER --> FORM

  FORM --> RV{"버전 이력 · revertBlock(page, versionId)"}
  RV -->|"versionId 를 못 찾음"| RV1["REVERT_NOT_FOUND — 버튼 disabled + title 에 사유"]
  RV -->|"지금 내용과 title·body 가 같음"| RV2["REVERT_SAME — 되돌릴 것이 없다"]
  RV -->|"되돌릴 수 있음"| RVM["useRevertSitePage → applyRevert(page, versionId, at, PAGE_ACTOR)<br/>**되돌리기도 새 판을 만든다** — 'vN 내용으로 되돌림'<br/>이력은 앞으로만 자란다(잘라 내지 않는다)"]
  RV1 --> FORM
  RV2 --> FORM
  RVM --> RVR{"결과"}
  RVR -->|"성공"| RVOK["toast '이전 판으로 되돌렸습니다.'<br/>invalidate ['site-pages','list'] · ['site-pages','detail',id]"]
  RVR -->|"실패 · ?fail=save"| RVER["toast '되돌리지 못했습니다…'"]
  RVOK --> Q
  RVER --> FORM

  %% ── 이 화면 밖으로 나가는 실 ──
  Q -.->|"메뉴 관리가 읽는다"| CAT["listCatalogSitePages → CatalogSitePage{id,title,slug,published}<br/>published = isSitePagePublic(page, now)<br/>조회기의 자리는 shared/domain/site-page-catalog · 배선은 src/wiring.ts<br/>메뉴 화면은 '페이지 관리' 라는 모듈을 끝까지 모른다"]

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class ST,F,ACT,DERIV,V,WARN,SF,MR,PVR,RV,RVR gate
  class ERRL,EMPTY,VE,VE2,VE3,SF1,SF2,ERRS,PVER,RV1,RV2,RVER,WY err
  class OKS,PVOK,RVOK ok
