%% 채용 공고 · /company/careers
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 · /company/careers"]) --> URL["useListState (IA-13)<br/>FILTER_DEFAULTS job='all' · employment='all' · state='all' · q<br/>parseFilter 로 손으로 고친 값은 'all' 로 되돌린다"]
  URL --> Q["useCrudList resource 'careers'<br/>careersAdapter (createCrudAdapter · sort: sortCareers)"]
  Q --> ST{"목록 조회 상태"}
  ST -->|"isPending"| LOAD["CrudListShell 스켈레톤"]
  ST -->|"isError · ?fail=list"| ERRL["인라인 Alert 배너 + 다시 시도"]
  ST -->|"visible.length = 0"| EMPTY["Empty label='채용 공고'<br/>hasQuery → 검색어 지우기 · hasActiveFilters → 필터 초기화"]
  ST -->|"성공"| LIST["CrudListShell<br/>공고 제목 · 직무 · 고용형태 · 근무지 · 마감일 · 상태<br/>rowTarget kind='edit' → /company/careers/:id/edit"]
  ERRL -->|"재시도"| Q

  %% ── 마감은 파생값이다 ──
  LIST --> STATE{"careerStateOf(career, today)<br/>**마감 여부를 저장하지 않는다**"}
  STATE -->|"!published"| ST_D["**draft** 비공개 (neutral)<br/>마감을 따지기 전에 아직 나가지 않은 공고다"]
  STATE -->|"closesOn === null"| ST_A["**always** 상시 채용 (info)<br/>null 은 '마감일을 아직 안 정함' 이 아니라 **의도**다"]
  STATE -->|"closesOn &lt; today"| ST_C["**closed** 마감 (warning)<br/>아무도 로그인하지 않은 새벽 0시에도 다음 조회에서 곧바로 마감이 된다<br/>고쳐 줄 배치가 필요 없다"]
  STATE -->|"그 외"| ST_O["**open** 모집 중 (success)<br/>마감일 **당일까지는 모집 중**이다 — D-day 를 잘라 내면 마지막 날이 없는 날이 된다"]

  LIST --> SORT["sortCareers — 살아 있는 공고가 위, 지난 공고가 아래<br/>rank: 상시 0 · 마감일 있음 1 · 비공개 2<br/>같은 rank 안에서는 **마감일 내림차순**<br/>('오늘' 을 받지 않는다 — 날마다 다른 순서로 저장되면 그 순서는 어디에도 없다)"]
  SORT --> LIST

  LIST --> F{"조회 조건 변경"}
  F -->|"직무 SelectField (JOB_FUNCTIONS 6종)"| SETQ
  F -->|"고용형태 SelectField (EMPLOYMENT_TYPES 4종)"| SETQ
  F -->|"상태 SelectField (always·open·closed·draft)"| SETQ
  F -->|"제목·근무지 검색 · 디바운스 (COMP-10 IME 안전)"| SETQ
  SETQ["URL 쿼리 갱신 · 기본값(all)은 제거<br/>filterCareers(…, today) → searchCareers(keyword)<br/>필터가 바뀌면 controller.clear() — 보이지 않는 행의 선택이 남지 않게<br/>today 는 useMemo 로 한 번만 만든다(자정 언저리에 두 답이 나오지 않게)"] --> Q

  LIST --> ACT{"액션 선택"}
  ACT -->|"채용 공고 등록 · canCreate (EXC-03)"| NEW["/company/careers/new"]
  ACT -->|"행 클릭 · 연필"| EDIT["/company/careers/:id/edit"]
  ACT -->|"휴지통 · SelectionBar"| DEL["CrudListShell 삭제 · 일괄 삭제 → invalidate list"]
  DEL --> Q

  %% ── 등록 · 수정 폼 ──
  NEW --> FORM
  EDIT --> FORM
  FORM["CareersFormPage · useCrudForm + FormPageShell<br/>제목 · 직무 · 고용형태 · 근무지 · 상시/마감일 · 지원 방법 · 공고 내용 · 공개"] --> ALW{"상시 채용을 **먼저** 묻는다 — 그 답이 마감일 칸의 존재를 정한다"}
  ALW -->|"on"| ALW1["마감일 칸이 사라지고 남아 있던 날짜를 지운다<br/>toInput 에서 closesOn = null 로 저장<br/>빈 문자열로 두면 '아직 안 정함' 과 구분되지 않는다"]
  ALW -->|"off"| ALW2["type='date' 마감일 칸"]
  ALW1 --> V
  ALW2 --> V

  V{"zodResolver(careerSchema)<br/>스키마는 **형식까지만** 본다"} -->|"제목 공백 · TITLE_MAX_LENGTH 100 초과"| VE
  V -->|"직무·고용형태 미선택"| VE
  V -->|"근무지 공백 · LOCATION_MAX_LENGTH 60 초과"| VE
  V -->|"closesOn 이 YYYY-MM-DD 아님"| VE2["'마감일 형식이 올바르지 않습니다.'<br/>**비어 있어도 통과한다** — 상시 채용이 그 모양이다"]
  V -->|"applyTarget 이 APPLY_TARGET_MAX_LENGTH 300 초과"| VE
  V -->|"공고 내용 공백 · DESCRIPTION_MAX_LENGTH 2000 초과"| VE
  VE["필드 인라인 에러 (첫 이슈만) · 제출 차단"] --> FORM
  VE2 --> FORM

  %% ── 지원 방법 가드 ──
  FORM --> AM{"applyMethodBlock(method, target)<br/>**지원 방법은 둘뿐이다** — 이메일 접수 · 외부 링크<br/>둘 다 공고가 **값을 통째로 갖는다**(이메일 주소 · 외부 주소)<br/>그래서 이 가드는 다른 화면의 상태를 묻지 않는다"}
  AM -->|"email · 주소 공백"| AM1["'지원서를 받을 이메일 주소를 입력하세요.'"]
  AM -->|"email · 형식 오류"| AM2["'이메일 주소 형식이 올바르지 않습니다.'"]
  AM -->|"link · 주소 공백"| AM3["'지원 페이지 주소를 입력하세요.'"]
  AM -->|"link · https:// 아님"| AM4["'지원 페이지 주소는 https:// 로 시작해야 합니다.<br/>지원자가 개인정보를 입력하는 화면입니다.'<br/>취향이 아니다 — 지원자가 **개인정보를 입력하는 화면**이다"]
  AM -->|"그 밖의 값 (옛 'form' 등)"| AM5["'지원 방법을 고르세요.'<br/>**fail-closed** — 저장돼 있던 옛 공고가 applyMethod: 'form' 을 들고 있어도<br/>공개 저장이 거절된다(선택지에도 없고 통과하지도 않는다)"]
  AM -->|"통과"| AMOK["Alert 없음"]
  AM1 --> AMINFO
  AM2 --> AMINFO
  AM3 --> AMINFO
  AM4 --> AMINFO
  AM5 --> AMINFO["Alert info — 사유 문자열 그대로(화면이 문구를 다시 짓지 않는다)"]
  AMINFO --> FORM

  GONE["**'지원 폼' 선택지는 제거됐다**(2026-07-22)<br/>그것만 다른 화면(폼 관리 /content/forms)이 만들고 고치고 지우는 것을 **참조**했다<br/>폼 관리 화면이 IA 에서 걷히면서 그 폼을 만들 곳이 사라졌으므로 선택지도 함께 걷는다 —<br/>**고를 수는 있는데 절대 공개할 수 없는 선택지는 기능이 아니라 함정이다**<br/>(그때의 안내 문구는 '폼 관리 연동이 준비되면 선택할 수 있습니다' 였다 — 오지 않을 미래였다)<br/>이음매 shared/domain/application-form.ts 도 함께 사라졌다"]
  GONE -.-> AM

  FORM --> PB{"publishBlock(input) = published 일 때만 applyMethodBlock 을 본다"}
  PB -->|"published = false"| PBOK["**비공개 저장은 언제나 허용**<br/>초안을 저장하지 못하게 만들면 작성 중인 내용이 사라진다"]
  PB -->|"published = true 인데 지원 경로가 안 열림"| PBNG["**공개로 저장되지 않는다** — careerSchema 의 check 가 사유를<br/>applyTarget 필드 이슈로 올리고, 어댑터도 같은 술어로 422 를 던진다<br/>열리지 않는 '지원하기' 는 기능이 아니라 거짓 약속이다"]
  PBNG --> FORM
  PBOK --> FORM

  V -->|"통과"| MUT["createCareer / updateCareer<br/>closesOn = alwaysOpen ? null : trim · saving 동안 버튼 잠금"]
  MUT --> MR{"mutation 결과"}
  MR -->|"성공"| OKS["토스트 성공 · invalidate lists · detail"]
  MR -->|"실패 · ?fail=save"| ERRS["폼 상단 serverError 배너 · 재제출 = 재시도"]
  ERRS --> FORM
  OKS --> BACK["복귀 · navigate(replace: true) → 목록"]
  BACK --> Q

  %% ── 판정 축 ──
  S -.->|"플랜(엔타이틀먼트)"| ENT["cms.pages 가 이 잎을 덮는다 (module-resources.ts)<br/>기업 관리 가지에 있을 뿐 **파는 단위는 CMS** 다<br/>TODO(backend): 마감 여부는 응답에 없다 — 서버도 저장하지 않는다"]

