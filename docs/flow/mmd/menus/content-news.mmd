%% 뉴스·보도자료 · /content/news
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 · /content/news"]) --> URL["useListState (IA-13)<br/>FILTER_DEFAULTS category='all' · status='all' · q<br/>parseFilter(filters['status'], NEWS_STATUS_FILTER_VALUES, 'all')<br/>all|draft|scheduled|published|archived"]
  URL --> Q["useCrudList resource 'news-posts'<br/>newsPostAdapter (createStoreAdapter)"]
  Q --> ST{"목록 조회 상태"}
  ST -->|"isPending"| LOAD["CrudListShell 스켈레톤"]
  ST -->|"isError · ?fail=list"| ERRL["인라인 Alert 배너 + 다시 시도<br/>counts = null (배지를 그리지 않는다)"]
  ST -->|"visibleItems.length = 0"| EMPTY["Empty label='뉴스'<br/>검색어 지우기 · 필터 초기화 · createAction"]
  ST -->|"성공"| LIST["좌 FilterRail/FilterPanel — 분류 · countByCategory 배지<br/>press 언론보도 / award 수상·인증 / notice 공시·알림<br/>우 CrudListShell — 제목 · 분류 · 상태 · 발행일 · 최근 수정<br/>rowTarget kind='edit' → /content/news/:id/edit"]
  ERRL -->|"재시도"| Q

  LIST --> SORT["sortNewsPosts — **고정 → 발행일 내림차순**<br/>고정은 '날짜와 무관하게 위' 라는 뜻이라 발행일보다 먼저 본다<br/>publishAt 이 '' 인 글은 updatedAt 을 대신 본다<br/>(정렬 기준이 비었다고 맨 아래로 몰리면 방금 쓴 초안을 못 찾는다)"]
  SORT --> LIST

  LIST --> DERIV{"newsStatus = effectivePublishStatus(post, now)<br/>페이지 관리와 **같은 한 벌**을 읽는다(publish-schedule)"}
  DERIV -->|"status !== 'published'"| D1["draft · archived 그대로"]
  DERIV -->|"publishAt = '' 또는 형식 아님"| D2["published"]
  DERIV -->|"publishAt &gt; now"| D3["**scheduled** — 저장되지 않는 파생 상태"]
  D1 --> BADGE
  D2 --> BADGE
  D3 --> BADGE["StatusBadge PUBLISH_STATUS_TONE/LABEL · 고정글은 tone=info '고정'"]

  LIST --> ATT{"첨부 배지 — attachmentWarning(attachmentIds, catalog)<br/>catalog = mediaCatalog()"}
  ATT -->|"첨부 0건"| AT0["배지 없음"]
  ATT -->|"catalog === null"| AT1["ATTACHMENT_UNKNOWN '첨부파일 목록을 확인할 수 없습니다.'<br/>tone=danger '첨부 확인 필요' — '모른다' 를 '삭제됨' 으로 뭉개지 않는다"]
  ATT -->|"가리키는 자산이 없음"| AT2["ATTACHMENT_MISSING '삭제된 파일을 가리키는 첨부가 있습니다.'"]
  ATT -->|"정상"| AT3["tone=neutral '첨부 N'"]

  LIST --> F{"조회 조건 변경"}
  F -->|"분류 FilterPanel"| SETQ
  F -->|"상태 SelectField"| SETQ
  F -->|"제목 검색 · 디바운스"| SETQ
  SETQ["URL 쿼리 갱신 · 기본값은 URL 에서 제거<br/>filterNewsPosts(items, status, categoryId, keyword, now)"] --> Q

  LIST --> ACT{"액션 선택"}
  ACT -->|"뉴스 등록 · canCreate"| NEW["/content/news/new"]
  ACT -->|"행 클릭 · 연필"| EDIT["/content/news/:id/edit"]
  ACT -->|"휴지통 · SelectionBar"| DEL["CrudListShell 삭제 · 일괄 삭제<br/>ConfirmDialog → useCrudDelete → invalidate list"]
  DEL --> Q

  %% ── 등록 · 수정 폼 ──
  NEW --> FORM
  EDIT --> FORM
  FORM["NewsFormPage · useCrudForm + FormPageShell<br/>제목 · 분류 · 상단 고정 · 상태 · 공개 일시 · 본문 · 첨부"] --> V{"zodResolver(newsPostSchema)"}
  V -->|"제목 공백 · NEWS_TITLE_MAX 100 초과"| VE
  V -->|"분류 미선택"| VE2["'분류를 고르세요.'"]
  V -->|"본문 공백 · NEWS_BODY_MAX 10000 초과"| VE
  V -->|"publishAt 이 isPublishAtFormat 아님"| VE3["PUBLISH_AT_INVALID"]
  V -->|"publishAt 이 있는데 status !== 'published'"| VE4["'공개 일시는 발행 상태에서만 지정할 수 있습니다.'"]
  VE["필드 인라인 에러 (첫 이슈만) · 제출 차단"] --> FORM
  VE2 --> FORM
  VE3 --> FORM
  VE4 --> FORM

  %% ── 첨부는 참조다 ──
  FORM --> PICK{"첨부 선택 — mediaCatalog()"}
  PICK -->|"null"| PK1["Alert warning — 지금은 첨부를 고를 수 없다<br/>미디어 라이브러리 링크(MEDIA_LIBRARY_PATH)만 남긴다"]
  PICK -->|"목록 있음"| PK2["SelectField 로 자산 선택<br/>withAttachment — 같은 파일을 두 번 붙이지 않는다(멱등)<br/>withoutAttachment — 행에서 연결 해제<br/>**파일을 복사해 들지 않는다** — 자산 id 만 든다"]
  PK1 --> FORM
  PK2 --> FORM
  FORM --> ATW["attachmentViews(attachmentIds, catalog)<br/>catalog 를 모르면 **전부 asset=null** 로 준다<br/>warning 이 있으면 Alert danger 로 그 사실을 먼저 말한다"]
  ATW --> FORM

  V -->|"통과"| MUT["createNewsPost / updateNewsPost<br/>updatedAt = stampNow() · saving 동안 버튼 잠금"]
  MUT --> MR{"mutation 결과"}
  MR -->|"성공"| OKS["토스트 성공 · invalidate lists · detail"]
  MR -->|"실패 · ?fail=save"| ERRS["폼 상단 serverError 배너 · 재제출 = 재시도"]
  ERRS --> FORM
  OKS --> BACK["복귀 · navigate(replace: true) → 목록"]
  BACK --> Q

  %% ── 이 화면 밖으로 나가는 실 ──
  Q -.->|"미디어 삭제 차단의 근거 절반"| USE["listNewsMediaUsage(assetId) → MediaUsageRef{id, domainLabel '뉴스', label, path}<br/>**초안·보관 글도 센다** — 발행하는 날 첨부가 비면 무엇이 붙었는지 아무도 모른다<br/>registerMediaUsageLookup('news', …) 은 src/wiring.ts 가 건다<br/>TODO(backend): GET /api/news?attachmentId="]

