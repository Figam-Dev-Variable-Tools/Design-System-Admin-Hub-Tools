%% 동의 이력 · /users/consents
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 · /users/consents"]) --> SCOPE["/content/terms 는 **문서 본문**을 관리한다<br/>문서가 있다는 것과 누가 그것에 동의했다는 것은 다른 사실이고<br/>분쟁에서 요구되는 것은 후자다 — 이 화면은 문서를 쓰지 않는다"]
  SCOPE --> Q1["useQuery consentItemsKey ['users','consents','items']<br/>consentItemsStore.fetch(signal)"]
  SCOPE --> Q2["useQuery consentEventsKey ['users','consents','events']<br/>fetchConsentEvents(signal) — newestFirst(LEDGER)"]

  Q1 --> IST{"항목 정의 조회 상태"}
  IST -->|"isFetching && data===undefined"| ILOAD["Skeleton (aria-busy · '동의 항목을 불러오는 중')"]
  IST -->|"error !== null"| IERR["Alert danger '동의 항목 정의를 불러오지 못했습니다. 아래는 기본 정의입니다.'<br/>+ [다시 시도]<br/>items = CONSENT_ITEM_SEED — 빈 배열로 그리면<br/>'동의 항목이 하나도 없는 서비스' 처럼 보인다"]
  IST -->|"성공"| ITEMS["items = itemsQuery.data.items"]
  IERR --> ITEMS
  ILOAD --> ITEMS

  ITEMS --> TABS{"Tabs — 세 질문의 답이 **같은 이력**에서 나온다"}
  TABS -->|"items"| T1["동의 항목 — ConsentItemsCard"]
  TABS -->|"history"| T2["동의 이력 — ConsentHistoryPanel"]
  TABS -->|"compliance"| T3["재동의 · 파기 — CompliancePanel"]

  %% ── ① 동의 항목 ──
  T1 --> NEC{"necessityChangeBlock(item, next) — 토글의 잠금과 저장의 거절이 같은 술어"}
  NEC -->|"next='optional'"| NECOK["언제나 허용 — 선택으로 내리는 것은 막지 않는다"]
  NEC -->|"purpose ∈ marketing · privacy-optional · third-party 를 'required' 로"| NECNG["**필수로 세울 수 없다**<br/>'…{성격} 동의라 필수로 바꿀 수 없습니다. 이 동의를 강제하면 미동의<br/>이용자의 가입이 막히고, 마케팅 수신 동의의 경우 최대 1,000만 원의 과태료 대상입니다.'<br/>Alert danger + 토글 disabled(사유를 그 자리에서 말한다)"]
  NEC -->|"service · privacy-essential"| NECOK
  NECNG --> T1
  NECOK --> DRAFT["draft 갱신 — dirty = draftKeyOf(draft) !== serverKey (파생값)"]
  T1 --> RO1["!canUpdate → Alert info '조회 권한만 있어 동의 항목을 변경할 수 없습니다.'<br/>저장 컨트롤 자체를 렌더하지 않는다 (EXC-03)"]

  DRAFT --> SUBMIT{"저장 — itemsSaveBlock(draft) 를 한 번 더 본다<br/>폼 값은 URL·개발자도구·다른 탭에서 바뀔 수 있다"}
  SUBMIT -->|"위반"| SNG["Alert danger — 같은 사유 문자열"]
  SUBMIT -->|"통과"| SMUT["saveItems.mutate(draft) → consentItemsStore.save({items})"]
  SNG --> T1
  SMUT --> SR{"결과"}
  SR -->|"성공"| SOK["invalidate consentItemsKey<br/>toast '동의 항목을 저장했습니다.'"]
  SR -->|"실패"| SERR["toast '동의 항목을 저장하지 못했습니다. 잠시 후 다시 시도해 주세요.'"]
  SOK --> Q1
  SERR --> T1

  %% ── ② 동의 이력 (append-only) ──
  T2 --> APPEND["**이력은 덧붙이기만 한다**<br/>이 화면에 수정·삭제 표면이 없다 — 고칠 수 있는 기록은 증거가 되지 못한다<br/>마음이 바뀐 것은 **철회 이벤트를 한 줄 더 쌓아** 표현한다<br/>현재 상태는 저장되지 않고 이력의 마지막 줄에서 파생된다(currentDecision)"]
  APPEND --> HURL["useListState (IA-13)<br/>FILTER_DEFAULTS item='all' · action='all' · q<br/>parseFilter — 손으로 고친 ?item=거짓말 은 '전체' 로 되돌린다"]
  HURL --> HST{"이력 조회 상태"}
  HST -->|"isFetching && data===undefined"| HLOAD["스켈레톤 (STATE-01 · 재조회 중에는 이전 행 유지)"]
  HST -->|"error !== null"| HERR["Alert 배너 + 다시 시도(refetch)"]
  HST -->|"성공"| HLIST["표 — 시각 · 대상(**마스킹된 표시값**) · 항목 · 구분 · 약관 버전 · 출처<br/>filterConsentEvents(itemId, action) → searchConsentEvents(keyword)<br/>검색 축: subjectLabel · subjectId · termsVersion<br/>철회에는 버전이 없다 → '—' (v1.1 로 지어내지 않는다)<br/>출처 CONSENT_SOURCES 7종 — 자유 입력이면 같은 화면이 네 이름으로 쌓인다"]
  HERR --> Q2

  %% ── ③ 재동의 · 파기 ──
  T3 --> RC{"reconsentTargets(events, items, activeTermsVersions())"}
  RC -->|"activeTermsVersions() === null (미배선)"| RCNULL["**null 을 돌려준다 — 빈 결과가 아니다**<br/>Alert warning '시행 중인 약관 버전을 확인할 수 없어 재동의 대상을 판정하지<br/>못했습니다. 대상이 없다는 뜻이 아닙니다…'<br/>0명이라고 적으면 운영자는 개정 공지를 보내지 않는다 —<br/>배선 사고가 법적 사고로 번지는 경로다"]
  RC -->|"item.termsTypeId 의 시행 버전을 못 찾음"| RCUNRES["unresolvedItems 에 라벨을 남긴다<br/>Alert warning — '대상 0명' 과 '판정 못 함' 은 다른 사실이다"]
  RC -->|"판정 성공"| RCG["groups — latestDecisions 중 action='granted' 이고<br/>termsVersion !== 시행 버전인 대상만<br/>**철회한 사람은 대상이 아니다** — 개정을 이유로 다시 권유하면<br/>철회 의사를 무시하는 재권유가 된다<br/>항목별 '시행 vN' · 'N명' 배지 + 대상 표(대상 · 동의한 버전)"]
  RCG -->|"groups.length === 0"| RCNONE["'모든 동의가 시행 중인 버전 기준입니다.'"]

  T3 --> PG["purgeTargets(events, items, today)<br/>latestDecisions 중 action='withdrawn' 인 것만<br/>withdrawnOn = seoulDayOf(occurredAt)<br/>purgeableFrom = addMonths(withdrawnOn, item.retentionMonths)<br/>— 말일은 그 달의 마지막 날로 붙인다(1/31 + 1개월이 3/3 이 되면 기간이 이틀 길어진다)<br/>purgeableFrom &gt; today 면 제외 · 오래 넘긴 것부터 정렬"]
  PG --> PGNOTE["**파기 '대상' 이지 파기가 아니다**<br/>이 화면은 지우지 않는다 — 실제 삭제는 원장과 백업을 함께 다뤄야 하는 서버의 일이다<br/>TODO(backend) · 할 수 없는 일을 버튼으로 만들지 않는다"]

  %% ── 권한 ──
  TABS -.->|"권한 축"| PERM["이력은 조회뿐이다 — 어떤 역할에게도 수정·삭제 표면이 없다<br/>항목 정의만 update 로 게이팅된다 (EXC-03)"]

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class IST,TABS,NEC,SUBMIT,SR,HST,RC gate
  class IERR,NECNG,SNG,SERR,HERR,RCNULL,RCUNRES err
  class NECOK,SOK,RCNONE ok
