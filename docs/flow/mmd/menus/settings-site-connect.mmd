%% 사이트 연동 · /settings/site-connect
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 /settings/site-connect"]) --> Q["useSettingsQuery(siteConnectKey, siteConnectStore)<br/>Revisioned&lt;SiteConnectDoc&gt; — 값 + revision + audit<br/>useForm(zodResolver(siteConnectSchema))<br/>data 도착 시 reset(toValues(data.value)) 로 기준선 설정<br/>**키 입력 칸은 언제나 비어서 온다** (채울 값을 우리도 갖고 있지 않다)"]
  Q --> LS{"SettingsFormShell 상태"}
  LS -->|"loadFailed (error !== null)"| E1["폼 대신 실패 화면 + '다시 시도'(refetch) · 재현: ?fail=load"]
  LS -->|"isFetching && data===undefined"| L1["카드 골격 + 스켈레톤 (STATE-01)"]
  LS -->|"!canUpdate"| RO["info 배너 '조회 권한만 있습니다. 사이트 연동을 바꾸려면<br/>시스템 설정 수정 권한이 필요합니다.'<br/>저장 컨트롤 자체를 렌더하지 않는다 (EXC-03)"]
  LS -->|"성공 · canUpdate"| OK1["폼 본문 + AuditNote(최종 수정자·시각)"]
  E1 --> Q
  L1 --> OK1
  RO --> OK1

  OK1 --> BLOCK{"enableBlock(values) — **토글의 disabled 와 저장 거절이 읽는 같은 술어**<br/>잠금은 '켜려 할 때' 만 건다 — 이미 켜진 연동은 끌 수 있어야 한다"}
  BLOCK -->|"siteUrl 공백"| B1["'홈페이지 도메인을 입력해야 연동을 켤 수 있습니다.<br/>어느 사이트에서 온 이벤트인지 확인할 방법이 없습니다.'"]
  BLOCK -->|"firstInvalidOrigin !== null"| B2["'추가 허용 출처 {origin} 의 형식이 올바르지 않습니다.<br/>https://호스트 형태로, 경로 없이 적어 주세요.'<br/>경로가 붙으면 브라우저의 Origin 헤더와 영영 일치하지 않아<br/>**모든 이벤트가 조용히 거절된다**"]
  BLOCK -->|"!hasSecret && secretInput 공백"| B3["'연동 키가 저장돼 있지 않습니다. 키 없이 연동을 켜면<br/>들어오는 이벤트를 검증할 수 없어 모두 거절됩니다.'"]
  BLOCK -->|"null"| BOK["토글 사용 가능"]
  B1 --> BINFO
  B2 --> BINFO
  B3 --> BINFO["ToggleSwitch disabled + Alert info 로 **그 자리에서** 이유를 말한다<br/>이유 없는 disabled 는 운영자에게 '고장' 으로 보인다"]
  BINFO --> OK1
  BOK --> OK1

  OK1 --> FIELDS["홈페이지 도메인 (HTTPS_URL_RE · SITE_URL_MAX 200)<br/>— **https 만 받는다**: 평문이면 유입 데이터가 관측이 아니라 추측이 된다<br/>추가 허용 출처 textarea (ALLOWED_ORIGINS_MAX 1000)<br/>연동 키 — 저장 여부만 배지로 · MASKED_SECRET_TEXT 는 **우리가 가진 정보의 전부**다<br/>secretInput: '' = 그대로 둔다 / 값 있음 = 교체 (SECRET_MAX 200)"]
  FIELDS --> OFFNOTE{"enabled"}
  OFFNOTE -->|"false"| OFF["상주 Alert info '연동이 꺼져 있습니다. 홈페이지에서 보내는<br/>유입·주문·문의 이벤트는 모두 거절됩니다.'"]
  OFFNOTE -->|"true"| ONN["경고 없음"]

  OK1 ~~~ SUB1

  subgraph SUB1["검증 · 저장"]
    FIELDS --> V{"siteConnectSchema (필드 단위만)"}
    V -->|"siteUrl 이 https:// 형식 아님"| V1["'https:// 로 시작하는 도메인을 입력하세요.'"]
    V -->|"siteUrl 200자 초과"| V2["'홈페이지 도메인이 너무 깁니다.'"]
    V -->|"allowedOrigins 1000자 초과"| V3["'추가 허용 출처가 너무 깁니다.'"]
    V -->|"secretInput 200자 초과"| V4["'연동 키가 너무 깁니다.'"]
    V1 --> VE
    V2 --> VE
    V3 --> VE
    V4 --> VE["필드 인라인 오류 · 입력 보존 (A11Y-11 aria-describedby)"]
    VE --> OK1
    V -->|"통과"| ONV["onValid — **여기서 저장하지 않는다**<br/>saveBlock(values) 를 한 번 더 본다(교차 필드는 스키마가 표현하지 못한다)"]
    ONV --> SB{"saveBlock"}
    SB -->|"출처 형식 오류"| SBNG["setRejected → Alert danger (저장 실패와 자리를 나눈다)"]
    SB -->|"enabled 인데 enableBlock !== null"| SBNG
    SB -->|"통과"| PEND["setPending(values)"]
    SBNG --> OK1
  end

  PEND --> CD{"ConfirmDialog intent='update' '사이트 연동 저장'"}
  CD -->|"켜진 채로 저장"| CD1["'저장하는 즉시 이 도메인에서 오는 이벤트를 받기 시작합니다. 저장할까요?'"]
  CD -->|"꺼진 채로 저장"| CD2["'연동이 꺼진 채로 저장합니다. 홈페이지에서 보내는 이벤트는 모두 거절됩니다. 저장할까요?'"]
  CD -->|"취소·Esc·딤"| CX["cancelSave — abort + save.reset() + lock.release()"]
  CX --> OK1
  CD1 --> M
  CD2 --> M["runSave(pending, force=false)<br/>[EXC-08] useSubmitLock 동기 잠금 — disabled 렌더를 기다리지 않는다<br/>save.mutate({value: toDoc(values), expectedRevision: data.revision, force, signal})<br/>**toDoc 에서 평문은 마지막으로 존재하고 버려진다** — hasSecret 불리언만 남는다"]

  M --> MR{"결과"}
  MR -->|"성공"| MOK["reset(toValues(saved.value)) — 새 기준선 · 키 칸은 다시 빈다<br/>toast '사이트 연동을 저장했습니다.'"]
  MR -->|"409 isSettingsConflict"| CF["setConflict(cause.latest) — **덮어쓰지 않는다** (EXC-04)"]
  MR -->|"isAbort"| AB["[EXC-09] 취소는 실패가 아니다 — 무시"]
  MR -->|"실패 · ?fail=save"| ME["saveError '사이트 연동을 저장하지 못했습니다…'<br/>확인 다이얼로그 안 배너 — 재클릭이 재시도"]
  ME --> M
  MOK --> Q

  CF --> CFD{"ConflictDialog subject='사이트 연동'<br/>divergedLabels(toDoc(getValues()), latest.value, SITE_CONNECT_FIELD_LABELS)"}
  CFD -->|"최신 내용 불러오기"| CF1["reset(toValues(latest.value)) + refetch<br/>toast '최신 사이트 연동 설정을 불러왔습니다.'"]
  CFD -->|"내 변경으로 덮어쓰기"| CF2["runSave(getValues(), force=true) → 다시 M"]
  CFD -->|"닫기"| CF3["closeConflict — abort + save.reset() + lock.release()"]
  CF1 --> OK1
  CF2 --> M
  CF3 --> OK1

  %% ── 유입 관측 (조회 전용) ──
  OK1 --> OBS["Card '최근 유입 관측' — listTrafficObservations()<br/>대상(마스킹) · 채널 · 캠페인 · 직전 페이지 · 최초 접점<br/>**편집 표면이 없다** — 관측값을 운영자가 고칠 수 있으면<br/>이 데이터는 측정이 아니라 의견이 되고 광고비 판단의 근거가 못 된다"]
  OBS --> TS{"toTrafficSource(raw) — 들어온 이벤트의 해석"}
  TS -->|"landedAt 이 없거나 파싱 불가"| TSNG["**null 을 돌려준다** — 시각을 지어내지 않는다<br/>new Date() 로 채우면 그것은 '고객이 들어온 때' 가 아니라<br/>'우리가 이벤트를 열어 본 때' 이고 기여도 시간축이 통째로 어긋난다"]
  TS -->|"channel 이 카탈로그 밖"| TSD["toTrafficChannel → **direct 로 흡수**한다<br/>'알 수 없음' 이라는 열 번째 값을 만들지 않는다 —<br/>리퍼러가 없는 유입은 직접 유입이 맞다"]
  TS -->|"정상"| TSOK["TrafficSource{channel, campaign, referrer, landedAt}<br/>campaign·referrer 는 string | null — **빈 문자열은 값이 아니다**"]
  TSD --> TSOK

  TSOK --> FT["firstTouch(existing, incoming) = existing ?? incoming<br/>**최초 접점 하나만 남긴다** — 마지막 클릭으로 덮어쓰면<br/>검색어를 만든 광고가 기여 0 으로 집계된다<br/>⚠ 짝이 되는 setTrafficSourceOf 는 **없고 앞으로도 만들지 않는다**"]
  FT --> WIRE["registerTrafficSourceLookup(findTrafficSource) — src/wiring.ts<br/>주문·문의·회원이 같은 좌표계로 읽는다(TrafficSubjectRef)<br/>TODO(backend): POST /api/site-connect/events — 웹훅 수신을 흉내 내지 않는다"]

  OK1 --> GUARD["미저장 이탈 가드 — dirty && !saving<br/>'사이트 연동에 저장하지 않은 변경 사항이 있습니다…'"]
  GUARD --> S

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class LS,BLOCK,OFFNOTE,V,SB,CD,MR,CFD,TS gate
  class E1,B1,B2,B3,BINFO,V1,V2,V3,V4,VE,SBNG,ME,CF,OFF,TSNG err
  class OK1,BOK,MOK,TSOK ok
