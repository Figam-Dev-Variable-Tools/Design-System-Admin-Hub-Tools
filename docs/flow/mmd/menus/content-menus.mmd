%% 메뉴 관리 · /content/menus
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 · /content/menus"]) --> SCOPE["**B2C 홈페이지의 메뉴 트리**다<br/>어드민 사이드바(nav-config.ts)와는 다른 세계이고<br/>이 화면은 그것을 알지 못한다 (types.ts 머리말)"]
  SCOPE --> URL["useListState (IA-13)<br/>FILTER_DEFAULTS location='header'<br/>parseFilter(filters['location'], MENU_LOCATIONS, 'header')<br/>header 상단 · footer 하단 · mobile 모바일"]
  URL --> Q["useCrudListQuery('site-menus', siteMenuAdapter)"]
  Q --> ST{"조회 상태"}
  ST -->|"isFetching && data===undefined"| SKEL["'불러오는 중…' (STATE-01 · 재조회 중에는 이전 행 유지)"]
  ST -->|"error !== null"| ERR1["Alert danger '메뉴를 불러오지 못했습니다.'<br/>[다시 시도] → refetch"]
  ST -->|"roots.length === 0"| EMP["Empty label='메뉴' + createButton"]
  ST -->|"성공"| TREE["Card + 2뎁스 트리<br/>rootMenus(menus, location) — order 오름차순<br/>childMenus(menus, root.id) — 들여쓰기 + 접기/펼치기<br/>aria-expanded · aria-controls (collapsed Set 은 화면 상태)"]
  ERR1 --> Q
  SKEL --> TREE

  %% ── 내부 참조의 건강 상태 ──
  TREE --> HEALTH{"menuLinkHealth(target, catalog)<br/>catalog = sitePageCatalog() — **저장하지 않고 볼 때마다 조회**한다<br/>외부 URL·게시판은 판정하지 않는다('ok')"}
  HEALTH -->|"catalog === null"| H_UNK["**unknown** — '모른다' 이지 '없다' 가 아니다<br/>Alert warning '페이지 목록을 불러올 수 없어 내부 링크가<br/>살아 있는지 확인하지 못했습니다.'<br/>빈 배열로 뭉개면 멀쩡한 트리가 전부 붉게 칠해진다"]
  HEALTH -->|"가리키는 페이지가 없음"| H_MISS["**missing** — StatusBadge danger '끊긴 링크'<br/>SITE_PAGE_REF_MISSING · brokenMenuCount 만큼 상단 Alert danger"]
  HEALTH -->|"페이지가 아직 공개 전"| H_HID["**hidden** — StatusBadge warning '공개 전'<br/>SITE_PAGE_REF_HIDDEN '발행하면 저절로 풀립니다'"]
  HEALTH -->|"공개된 페이지"| H_OK["**ok** — DetailCellLink '페이지 열기'<br/>sitePageEditPath(pageId) → /content/pages/:id/edit"]

  TREE --> ROW{"행 액션"}
  ROW -->|"메뉴 추가 · canCreate"| MCREATE["modal = create · parentId=null"]
  ROW -->|"하위 메뉴 추가 (1뎁스에만)"| MCHILD["modal = create · parentId=root.id"]
  ROW -->|"연필 · canUpdate"| MEDIT["modal = edit · menu"]
  ROW -->|"노출 토글 · canUpdate"| VIS
  ROW -->|"순서 위·아래 · canUpdate"| MOVE
  ROW -->|"휴지통 · canRemove"| DGATE

  %% ── 노출 토글 ──
  VIS["useSetSiteMenuVisible → setSiteMenuVisible(id, visible)<br/>지우지 않고 잠깐 내리는 손잡이<br/>TODO(backend): PATCH /api/site-menus/:id/visible"] --> VISR{"결과"}
  VISR -->|"성공"| VISOK["toast '{label} 메뉴를 노출/숨김으로 바꿨습니다.'<br/>invalidate ['site-menus','list']"]
  VISR -->|"isAbort"| VISAB["[EXC-09] 취소는 실패가 아니다 — 무시"]
  VISR -->|"실패 · ?fail=save"| VISER["toast '노출 여부를 바꾸지 못했습니다…'"]
  VISOK --> Q
  VISER --> TREE

  %% ── 순서 이동 ──
  MOVE["moveArrayItem(형제 id 배열, index, index+delta)<br/>**형제 안에서만** 움직인다<br/>useReorderSiteMenus → renumberSiblings(1..n 재번호)<br/>reorder.isPending 동안 locked (ReorderMoveButtons)"] --> MOVER{"결과"}
  MOVER -->|"성공"| MOVEOK["invalidate ['site-menus','list']"]
  MOVER -->|"실패"| MOVEER["toast '순서를 바꾸지 못했습니다…'"]
  MOVEOK --> Q
  MOVEER --> TREE

  %% ── 삭제 가드 ──
  DGATE{"menuDeleteBlock(menus, menuId)"} -->|"하위 메뉴가 있음"| DBLOCK["MENU_DELETE_HAS_CHILDREN<br/>'하위 메뉴가 있어 삭제할 수 없습니다…'<br/>버튼 disabled + title/aria-label 이 **그 사유 문자열 그대로**<br/>부모를 지우면 자식이 유령이 된다"]
  DGATE -->|"자식 없음"| DLG{"ConfirmDialog intent='delete' '메뉴 삭제'"}
  DBLOCK --> TREE
  DLG -->|"취소 closeDelete (abort + reset)"| TREE
  DLG -->|"확인"| DELM["useCrudDelete → removeSiteMenu(id)<br/>저장소가 같은 술어를 다시 읽는다 → HttpError 409"]
  DELM --> DELR{"결과"}
  DELR -->|"성공"| DELOK["toast '{label} 메뉴를 삭제했습니다.' · invalidate list"]
  DELR -->|"실패"| DELER["다이얼로그 안 Alert '삭제하지 못했습니다…' · 재클릭 = 재시도"]
  DELOK --> Q
  DELER --> DLG

  SUB1 ~~~ SUB2

  subgraph SUB1["SiteMenuFormModal — 등록·수정 공용 (editing 유무로 갈린다)"]
    MCREATE --> MODAL
    MCHILD --> MODAL
    MEDIT --> MODAL
    MODAL["메뉴 이름(MENU_LABEL_MAX 30) · 위치 · 상위 메뉴 · 링크 대상<br/>**폼 값은 평면**이다 — 종류를 바꿔도 방금 쓴 URL 이 사라지지 않게<br/>상위 후보 = parentCandidates(같은 위치의 1뎁스만)"] --> TKIND{"링크 대상 targetKind"}
    TKIND -->|"page 내부 페이지"| TP{"sitePageCatalog()"}
    TP -->|"null"| TPN["Alert warning '페이지 목록을 불러올 수 없어 지금은<br/>내부 페이지를 고를 수 없습니다…'<br/>**빈 목록이 아니라 문장으로** 알린다"]
    TP -->|"목록 있음"| TPS["SelectField — '{title} (/{slug})' · 미공개면 ' · 공개 전' 꼬리표"]
    TKIND -->|"external 외부 링크"| TE["type='url' · http:// 또는 https://"]
    TKIND -->|"board 게시판"| TB["BOARD_LABEL — news 뉴스·보도자료 / notices 공지사항 / faq FAQ"]
    TPN --> TYPE
    TPS --> TYPE
    TE --> TYPE
    TB --> TYPE
    TYPE["입력 · isDirty"] --> CLOSE{"닫기 시도 — useModalDirtyGuard(isDirty && !saving)<br/>Esc·딤·×·취소 4경로 (FEEDBACK-06)"}
    CLOSE -->|"계속 편집"| TYPE
    CLOSE -->|"버리기"| TREE
    TYPE --> SUBMIT["Modal onSubmit → clearErrors → handleSubmit(onValid, focus)"]
  end

  subgraph SUB2["검증 · 저장"]
    SUBMIT --> ZOD{"siteMenuSchema"}
    ZOD -->|"메뉴 이름 공백·30자 초과"| ZE1["requiredText 메시지"]
    ZOD -->|"page 인데 pageId 공백"| ZE2["MENU_PAGE_REQUIRED '연결할 페이지를 고르세요.'"]
    ZOD -->|"external 인데 url 공백"| ZE3["MENU_URL_REQUIRED"]
    ZOD -->|"url 이 MENU_URL_MAX 300 초과"| ZE4["'주소는 300자를 넘을 수 없습니다.'"]
    ZOD -->|"http(s):// 로 시작하지 않음"| ZE5["MENU_URL_FORMAT"]
    ZE1 --> TYPE
    ZE2 --> TYPE
    ZE3 --> TYPE
    ZE4 --> TYPE
    ZE5 --> TYPE
    ZOD -->|"통과"| FOLD["toMenuTarget(values) — 평면 값을 판별 유니온으로 접는다<br/>parentId '' → null · order 는 등록이면 저장소가 다시 계산"]
    FOLD --> ASSERT{"assertSavable(input, selfId) — 손으로 만든 요청이 여기서 막힌다"}
    ASSERT -->|"parentId = selfId"| A1["MENU_PARENT_SELF '자기 자신을 상위 메뉴로 둘 수 없습니다.'"]
    ASSERT -->|"상위를 못 찾음"| A2["MENU_PARENT_MISSING"]
    ASSERT -->|"상위가 이미 2뎁스"| A3["MENU_DEPTH_LIMIT '메뉴는 2단계까지만…'"]
    ASSERT -->|"자식이 있는 메뉴를 남의 하위로"| A3
    ASSERT -->|"상위와 위치가 다름"| A4["MENU_PARENT_LOCATION"]
    ASSERT -->|"menuTargetBlock 위반"| A5["대상 사유 문자열 그대로 · HttpError 422"]
    A1 --> SERR
    A2 --> SERR
    A3 --> SERR
    A4 --> SERR
    A5 --> SERR
    ASSERT -->|"통과"| MUT["create.mutate / update.mutate<br/>addSiteMenu → nextMenuOrder 로 자리를 저장소가 정한다"]
    MUT --> RES{"결과"}
    RES -->|"성공"| OK["modal 닫힘 + toast '{label} 메뉴를 추가/저장했습니다.'<br/>invalidate ['site-menus','list']"]
    RES -->|"isAbort"| ABORT["무시"]
    RES -->|"그 외"| SERR["Alert danger '저장하지 못했습니다…' · 모달 유지"]
    SERR --> TYPE
  end

  OK --> Q
  ABORT --> TREE

