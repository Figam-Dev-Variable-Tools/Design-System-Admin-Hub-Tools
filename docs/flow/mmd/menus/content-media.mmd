%% 미디어 라이브러리 · /content/media
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
  S(["진입 · /content/media"]) --> URL["useListState (IA-13)<br/>FILTER_DEFAULTS folder='all' · tag='' · q"]
  URL --> Q["useCrudListQuery('media-assets', mediaAssetAdapter)"]
  Q --> ST{"조회 상태"}
  ST -->|"isFetching && data===undefined"| SKEL["'불러오는 중…' (STATE-01)"]
  ST -->|"error !== null"| ERR1["Alert danger '파일 목록을 불러오지 못했습니다.'<br/>[다시 시도] → refetch · counts = null"]
  ST -->|"visible.length === 0"| EMP["Empty label='파일' · 검색어 지우기 · 필터 초기화 · createButton"]
  ST -->|"성공"| LIST["좌 FilterRail/FilterPanel — 폴더 · countByFolder 배지<br/>우 카드 목록 (표가 아니다 — 행마다 삭제 가능 여부와 사유가 다르다)<br/>ImageThumb · 파일명 · 대체텍스트 · 폴더 · 확장자·용량 · 태그<br/>정렬 sortMediaAssets — uploadedAt 내림차순"]
  ERR1 --> Q
  SKEL --> LIST

  LIST --> F{"조회 조건 변경"}
  F -->|"폴더 FilterPanel"| SETQ
  F -->|"태그 SelectField · collectTags(파생 목록)"| SETQ
  F -->|"파일명·대체텍스트 검색"| SETQ
  SETQ["URL 쿼리 갱신 · filterMediaAssets(assets, folderId, tag, keyword)"] --> Q

  %% ── 사용처는 삭제를 막는 근거다 ──
  LIST --> USE["usageById — 목록을 그릴 때 **한 번에** 모은다<br/>행마다 부르면 한 화면의 두 행이 서로 다른 시점의 답을 갖는다<br/>mediaUsage(assetId) — shared/domain/media-library"]
  USE --> UG{"조회기 상태"}
  UG -->|"registerMediaUsageLookup 이 한 건도 없음"| U_NULL["**null — '모른다'**<br/>배지 usageTone(null)=warning · usageLabel '확인 불가'<br/>펼치면 '사용처를 확인할 수 없습니다. 확인되기 전에는 삭제할 수 없습니다.'"]
  UG -->|"0건"| U_ZERO["배지 neutral '미사용' — 지워도 된다"]
  UG -->|"N건"| U_SOME["배지 info 'N곳 사용 중'<br/>펼치면 MediaUsageRef 링크 목록 ('뉴스 · {제목}' → /content/news/:id/edit)"]

  LIST --> ROW{"행 액션"}
  ROW -->|"사용처 배지 (aria-expanded/controls)"| USE
  ROW -->|"파일 등록 · canCreate"| MCREATE["modal = create"]
  ROW -->|"연필 · canUpdate"| MEDIT["modal = edit · asset"]
  ROW -->|"휴지통 · canRemove"| DGATE

  %% ── 삭제 가드 — fail-closed ──
  DGATE{"mediaDeleteBlock(usage)<br/>버튼의 disabled 와 저장소의 거절이 **이 한 함수**를 함께 읽는다"} -->|"usage === null"| DB1["MEDIA_DELETE_UNKNOWN<br/>'사용처를 확인할 수 없어 삭제할 수 없습니다…'<br/>**모르면 더 막는다** — '모른다' 를 '안 쓰인다' 로 뭉개면<br/>배선이 빠진 날 라이브러리가 통째로 비워진다 (fail-closed)"]
  DGATE -->|"usage.length &gt; 0"| DB2["mediaDeleteInUse(N) 'N곳에서 사용 중이라 삭제할 수 없습니다.<br/>사용처에서 먼저 연결을 끊어 주세요.'"]
  DGATE -->|"0건"| DLG{"ConfirmDialog intent='delete' '파일 삭제'"}
  DB1 --> BLOCKED["버튼 disabled + title/aria-label 이 **그 사유 문자열 그대로**<br/>화면이 사유를 다시 지어내지 않는다"]
  DB2 --> BLOCKED
  BLOCKED --> LIST

  DLG -->|"취소 closeDelete (abort + reset)"| LIST
  DLG -->|"확인"| DELM["useCrudDelete → removeMediaAsset(id)<br/>저장소가 mediaDeleteBlock(mediaUsage(id)) 를 다시 읽는다 → HttpError 409"]
  DELM --> DELR{"결과"}
  DELR -->|"성공"| DELOK["toast '{fileName} 파일을 삭제했습니다.' · invalidate list"]
  DELR -->|"isAbort"| DELAB["[EXC-09] 취소는 실패가 아니다 — 무시"]
  DELR -->|"실패"| DELER["다이얼로그 안 Alert '삭제하지 못했습니다…' · 재클릭 = 재시도"]
  DELOK --> Q
  DELER --> DLG

  SUB1 ~~~ SUB2

  subgraph SUB1["MediaAssetFormModal — 등록·수정 공용"]
    MCREATE --> MODAL
    MEDIT --> MODAL
    MODAL["파일 이름 · 용량(바이트) · 폴더 · 태그 · **대체텍스트**<br/>url 은 수정 시 기존 값 · 등록은 MEDIA_PLACEHOLDER_URL<br/>실제 업로드는 없다 — 백엔드가 붙으면 File 이 값을 준다"] --> DUP{"findDuplicate(assets, {fileName, sizeBytes})<br/>이름 + 크기로 본다(해시는 내용을 읽을 수 있게 된 뒤)"}
    DUP -->|"같은 이름·크기가 이미 있음"| DUPW["Alert warning duplicateWarningMessage<br/>**막지 않고 알린다** — 같은 이름의 다른 개정본을 올리는 일은 정당하다"]
    DUP -->|"없음"| TYPE
    DUPW --> TYPE
    TYPE["입력 · isDirty"] --> CLOSE{"닫기 시도 — useModalDirtyGuard(isDirty && !saving)<br/>Esc·딤·×·취소 4경로 (FEEDBACK-06)"}
    CLOSE -->|"계속 편집"| TYPE
    CLOSE -->|"버리기"| LIST
    TYPE --> SUBMIT["Modal onSubmit → clearErrors → handleSubmit(onValid, focus)"]
  end

  subgraph SUB2["검증 · 저장 — 규칙의 정본은 types.uploadBlock 이다"]
    SUBMIT --> ZOD{"mediaAssetSchema"}
    ZOD -->|"파일 이름 공백"| Z1["FILE_NAME_REQUIRED"]
    ZOD -->|"ALLOWED_EXTENSIONS 밖"| Z2["extensionBlockedMessage<br/>이미지 jpg·jpeg·png·gif·webp·svg / 문서 pdf·dwg·zip·xlsx·docx·pptx<br/>exe·sh·html 을 받지 않는 이유는 용량이 아니라 **안전**이다"]
    ZOD -->|"용량이 숫자가 아니거나 0 이하"| Z3["'용량을 바이트 단위 숫자로 입력하세요.'"]
    ZOD -->|"MAX_SIZE_BYTES 20MB 초과"| Z4["sizeBlockedMessage"]
    ZOD -->|"대체텍스트 공백"| Z5["ALT_REQUIRED '…화면을 읽어 주는 사용자에게는 이 문장이 곧 이미지입니다.'<br/>**올리는 순간에 받는다** — 나중에 채우겠다는 약속은 지켜지지 않는다"]
    ZOD -->|"ALT_MAX 100 초과"| Z6["ALT_TOO_LONG"]
    Z1 --> TYPE
    Z2 --> TYPE
    Z3 --> TYPE
    Z4 --> TYPE
    Z5 --> TYPE
    Z6 --> TYPE
    ZOD -->|"통과"| MUT["parseTags(쉼표·줄바꿈 · 중복 제거) · extensionOf(fileName)<br/>create.mutate / update.mutate"]
    MUT --> ASSERT{"저장 경로가 uploadBlock 을 다시 읽는다"}
    ASSERT -->|"위반"| SERR["HttpError 422 → Alert danger '저장하지 못했습니다…' · 모달 유지"]
    ASSERT -->|"통과"| RES{"결과"}
    RES -->|"성공"| OK["modal 닫힘 + toast '{fileName} 파일을 등록/저장했습니다.'<br/>invalidate ['media-assets','list']"]
    RES -->|"isAbort"| ABORT["무시"]
    RES -->|"그 외"| SERR
    SERR --> TYPE
  end

  OK --> Q
  ABORT --> LIST

  %% ── 이 화면 밖으로 나가는 실 ──
  Q -.->|"첨부하는 쪽이 읽는다"| CAT["listCatalogMediaAssets → CatalogMediaAsset{id, fileName, url, alt, sizeBytes}<br/>alt 를 함께 넘긴다 — 접근성은 복사되지 않으면 사라진다<br/>registerMediaCatalogLookup 은 src/wiring.ts 가 건다<br/>**카탈로그는 fail-open('못 고름'), 사용처는 fail-closed('못 지움')** — 기본값이 다른 것은 규칙이다"]

  classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
  classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
  classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d

  class ST,F,UG,ROW,DGATE,DLG,DELR,DUP,CLOSE,ZOD,ASSERT,RES gate
  class ERR1,EMP,U_NULL,DB1,DB2,BLOCKED,DELER,DUPW,Z1,Z2,Z3,Z4,Z5,Z6,SERR err
  class U_ZERO,U_SOME,OK,DELOK ok
