  LS -->|"!canUpdate"| RO["info 배너 '조회 권한만 있습니다. 결제 설정을 바꾸려면<br/>시스템 설정 수정 권한이 필요합니다.'<br/>저장 컨트롤 자체를 렌더하지 않는다 (EXC-03)"]
  LS -->|"성공 · canUpdate"| OK1["목록 본문 + AuditNote(최종 수정자·시각)"]
  E1 --> Q
  L1 --> OK1
  RO --> OK1

  OK1 --> SW{"**① 결제 연동** — ToggleSwitch 'PG 결제 사용'<br/>이 스위치 하나가 판매 방식을 정한다"}
  SW --> FACT["**미리보기가 아니라 사실 한 줄**<br/>'지금 사이트 전체: {siteWideFact}'<br/>가짜 상품 카드를 그리지 않는다 — 그 카드가 실제 상품 화면과<br/>어긋나는 날 아무도 눈치채지 못한다<br/>판정을 소유한 함수가 낸 문장을 그대로 옮긴다<br/>(resolvePriceDisplay · checkoutCta — 상품·프로그램이 읽는 것과 **같은 출처**)"]

  FACT --> TILES{"**두 묶음은 하나의 카탈로그에서 파생된다** — 목록을 복제하지 않는다<br/>pgTileStatus(settings, target) 3상태"}
  TILES -->|"in-use"| T1["**② 사용하고 있는 결제 서비스**<br/>usePg 이고 이 대상이 지금 연결이다"]
  TILES -->|"ready · idle"| T2["**③ 연동할 수 있는 결제 서비스**<br/>ready = 값은 저장돼 있고 마스터 스위치만 꺼짐<br/>idle = 그 밖 · 빈 연결(emptyConnection('toss'))도 여기다"]
  T1 --> EMPTYNOTE
  T2 --> EMPTYNOTE["②가 비었을 때가 이 화면의 핵심 상태다<br/>'지금은 결제 없이 운영합니다 — 구매하기·후원하기가 모두 문의하기로 나갑니다.'<br/>+ 접수 창구 링크 둘 (INQUIRY_PATH.product · INQUIRY_PATH.program)"]

  T1 --> DETAIL(["타일 클릭 → 주소가 바뀐다 · /settings/payment/:target"])
  T2 --> DETAIL

  SW -->|"usePg === false"| SEC4["**④ 문의 전환 안내** (껐을 때만 존재)<br/>안내 문구 TextareaField (INQUIRY_GUIDE_MAX 200)<br/>hint '상품 카드와 프로그램 상세의 문의하기 버튼 아래에 그대로 보입니다.'"]

  SW --> HALF{"halfConfigured = usePg && !pgSellable(설정, usePg=true)<br/>목록은 자격증명을 **검증하지 않는다** — 고칠 칸이 이 화면에 없다"}
  HALF -->|"참"| HW["warning 배너 '{PG} 자격증명이 아직 다 채워지지 않았습니다 ({빠진 칸들}).<br/>지금 저장해도 결제창은 열리지 않고 구매·후원 버튼은 문의하기로 남습니다.'<br/>+ 상세로 가는 링크 '{PG} 자격증명 채우기'"]
  HW --> DETAIL

  SEC4 --> AXIS
  HALF --> AXIS

  AXIS{"**축은 하나다 — pgSellable(settings)** (fail-closed)<br/>ⓐ usePg 가 켜져 있는가<br/>ⓑ readPgCredentialHealth() !== 'invalid' (백엔드만 아는 사실)<br/>ⓒ connectionComplete(connection) — 필수 공개 값 + 필수 비밀이 다 있는가<br/>※ contractStatus 는 **일부러 보지 않는다** — 손으로 적는 값이라<br/>오타 하나가 상점 전체를 닫는다. 막는 대신 reason 이 말한다"}
  AXIS -->|"false"| CTA1["checkoutCta → kind 'inquiry' · label '문의하기'<br/>reason: usePg 면 '{PG} 필수 자격증명이 아직 채워지지 않아({빠진 칸}) 결제창을 열 수 없습니다.'<br/>아니면 'PG 결제를 쓰지 않도록 설정되어 있어 결제 대신 문의로 받습니다.'<br/>inquiryPath = INQUIRY_PATH[domain]"]
  AXIS -->|"true"| CTA2{"mode · contractStatus"}
  CTA2 -->|"mode === 'test'"| CTA2a["kind 'purchase' · '{PG} 테스트 모드로 결제창이 열립니다.<br/>실제 결제는 일어나지 않습니다.'"]
  CTA2 -->|"contractStatus !== 'live'"| CTA2b["kind 'purchase' · '자격증명은 다 넣었지만 계약 상태가 「실결제 오픈」 이 아닙니다.<br/>카드사 심사 중이라면 결제창은 떠도 실결제가 승인되지 않습니다.'"]
  CTA2 -->|"그 외"| CTA2c["kind 'purchase' · label product '구매하기' / program '후원하기'<br/>'{PG} 결제창이 열립니다.' · inquiryPath = null"]

  AXIS -.->|"같은 술어를 읽는 다른 축들"| FAN["pgLock(settings, section) — 잠금은 **값을 지우지 않는다**<br/>product-points · product-coupons · product-stock<br/>· product-shipping · coupon-admin · points-policy<br/>(옵션 구성과 상품 등록 자체는 잠기지 않는다)<br/><br/>resolvePriceDisplay(readPaymentSettings()) — **축이 하나다**<br/>상품별 priceDisplay·inquiryText 는 제거됐다(ADR-0015)<br/>kind 'inquiry' 면 금액 자리에 '가격문의' + amountFieldsLocked = true<br/>둘은 항상 같은 값이다 — 갈리면 '금액은 입력되는데 표시는 문의' 가 생긴다<br/><br/>inquiryMenuState 도 같은 술어 위에 선다"]

  OK1 ~~~ SUB1

