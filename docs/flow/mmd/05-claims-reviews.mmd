%% 클레임 처리 · 리뷰 노출 관리 · /orders/claims · /products/reviews
%%{init: {"flowchart": {"curve": "step", "nodeSpacing": 25, "rankSpacing": 38, "wrappingWidth": 170}, "themeVariables": {"fontSize": "13px"}} }%%
flowchart TD
    C0(["클레임 접수 — 고객이 만든다<br/>어드민에 등록 라우트가 없다 (유형 E)"]) --> KIND{"ClaimKind 3종 — 셋을 가르는 것은 출고 시점"}
    KIND -->|"취소 cancel · 출고 전에 멈춘다"| CB{"cancelBlock(order)"}
    KIND -->|"반품 return · 나갔다 돌아온다"| S1
    KIND -->|"교환 exchange · 돌아오고 다시 나간다"| S1

    CB -->|"order === null"| CBU["CLAIM_ORDER_UNKNOWN<br/>연결된 주문을 확인할 수 없어 취소를 진행할 수 없습니다<br/>모르면 막는다 · fail-closed"]
    CB -->|"hasLeftWarehouse(order.status)"| CBS["CLAIM_CANCEL_SHIPPED<br/>배송이 시작된 주문은 취소로 처리할 수 없습니다.<br/>반품으로 접수해 주세요.<br/>판정은 주문 도메인의 것을 그대로 읽는다"]
    CB -->|"null"| C2["claimFlow(cancel) = 접수 → 완료 · **2단**<br/>수거·검수가 없다 — 물건이 아직 창고에 있다"]

    S1["접수 requested"] --> S2["수거중 collecting"] --> S3["검수중 inspecting"] --> GO
    C2 --> GO

    S1 --> OFF{"흐름 밖 종료 — 어느 단계에서나"}
    S2 --> OFF
    S3 --> OFF
    OFF -->|"반려 rejected · 언제나 통과"| ENDX["처리 종료 — 스텝퍼 대신 StatusBadge"]
    OFF -->|"철회 withdrawn · **유일한 역방향 전이**"| WG{"되돌릴 수 없는 것이 이미 일어났나"}
    WG -->|"stockAppliedAt 이 비어 있지 않다"| WG1["CLAIM_WITHDRAW_STOCK<br/>재고가 이미 반영되어 철회할 수 없습니다"]
    WG -->|"refund.status 가 none 이 아니다"| WG2["CLAIM_WITHDRAW_REFUND<br/>환불이 접수되어 철회할 수 없습니다"]
    WG -->|"null"| ENDX

    GO{"movesStock(claim)<br/>= status 가 completed 이고 kind 가 cancel 이 아니다"}
    GO -->|"취소 · 거짓"| NOSTK["**취소 클레임은 재고를 움직이지 않는다**<br/>출고 전 재고 복원은 주문이 소유한다(order.ts 의 stockRestoredAt)<br/>둘 다 되돌리면 같은 수량이 두 번 들어온다"]
    GO -->|"반품·교환 · 참"| VS{"validateStockPlan(claim, variants)"}
    VS -->|"unknown-origin · no-option · unknown-option · insufficient-stock"| VSX["완료 처리 불가 — 사유를 버튼 옆에 그대로 쓴다<br/>가드는 boolean 이 아니라 **사유 문자열**을 돌려준다<br/>같은 술어를 어댑터가 다시 불러 422 로 거절한다"]
    VSX --> S3
    VS -->|"null"| IDEM{"isStockApplied(claim)"}
    IDEM -->|"stockAppliedAt 있음"| SKIP["중복 반영 차단 — 재고는 한 번만 움직인다"]
    IDEM -->|"미반영"| MOVE["ConfirmDialog 뒤 planStockMovements<br/>반품 = 회수분 in · 교환 = 회수분 in + 재발송분 out<br/>성공해야 stockAppliedAt 을 각인한다(멱등키)"]
    NOSTK --> CDONE
    SKIP --> CDONE
    MOVE --> CDONE["완료 completed — 클레임 축 종료"]

    SUBR ~~~ SUBV

    subgraph SUBR["환불 축 — 클레임 상태와 나란한 **별개의 축** (교환은 대상 아님)"]
        CDONE -.->|"클레임 완료 ≠ 환불 완료 — 목록에 환불 열이 따로 있는 이유"| RF0
        RF0(["refund.status : none 환불 없음 → requested 환불 접수 → completed 환불 완료"]) --> RFK{"isRefundable(kind)"}
        RFK -->|"교환"| RFN["REFUND_NOT_REFUNDABLE · 카드 자체가 없다<br/>목록은 해당 없음 — 교환에 환불 없음 을 달면<br/>아직 안 한 일처럼 읽힌다"]
        RFK -->|"취소·반품"| RFC["refundBreakdown — 화면은 스스로 빼지 않는다<br/>total = max(0, paidAmount − returnShippingFee − couponClawback)<br/>couponClawback 은 쿠폰을 복원할 때만 (두 번 받는 것을 회수)<br/>defaultReturnFee: 취소는 언제나 0 · 정책을 모르면 직접 입력"]
        RFC --> RFB{"refundTransitionBlock(claim, to)"}
        RFB -->|"이미 completed"| RB1["REFUND_TRANSITION_DONE<br/>환불이 완료되어 더 이상 바꿀 수 없습니다"]
        RFB -->|"역행"| RB2["REFUND_TRANSITION_BACKWARD<br/>환불 처리는 되돌릴 수 없습니다"]
        RFB -->|"클레임이 rejected · withdrawn"| RB3["REFUND_CLAIM_CLOSED<br/>반려·철회된 클레임은 환불할 수 없습니다"]
        RFB -->|"completed 로 가는데 클레임 미완료"| RB4["REFUND_CLAIM_INCOMPLETE<br/>클레임 처리를 완료해야 환불을 완료할 수 있습니다<br/>두 축의 순서는 이 한 줄이 정한다"]
        RFB -->|"적립금을 썼는데 비회원"| RB5["REFUND_NO_MEMBER<br/>되돌릴 원장이 없어 환불을 완료할 수 없습니다"]
        RFB -->|"null"| RACT["환불 접수 requested → 환불 완료 completed"]
        RACT --> RREST["**적립금·쿠폰 복원은 completed 에서만** 일어난다<br/>planRefundRestoration — 접수·수거에서 미리 되돌리지 않는다<br/>(반려·철회된 고객이 적립금을 챙기게 되므로)<br/>refund.completedAt 이 멱등키 · 원장은 append-only"]
    end

    subgraph SUBV["리뷰 노출 관리 · /products/reviews — 상태 enum 이 없다"]
        RV0(["리뷰 등록 — 고객이 쓴다"]) --> RVF{"reported<br/>신고도 고객이 접수한다 — 운영자가 만드는 값이 아니다"}
        RVF -->|"true"| RVR["상세에 Alert warning · reportReason 또는 사유 미기재<br/>운영자는 읽고 노출 여부로 답한다"]
        RVF -->|"false"| RVJ
        RVR --> RVJ{"운영자 판단 — boolean 둘뿐(visible · reply)"}
        RVJ -->|"노출"| RVA["visible = true"]
        RVJ -->|"숨김"| RVB["visible = false"]
        RVA --> RVQ{"답변할까"}
        RVQ -->|"예"| RVD["reply 작성 · REVIEW_REPLY_MAX 500<br/>미리보기가 실시간으로 같은 값을 그린다"]
        RVQ -->|"아니오"| RVE["미답변 유지 — reply 가 빈 문자열"]
        RVB -.->|"목록 인라인 토글과 상세 저장이 **같은 필드**를 쓴다<br/>토글은 확인 게이트 없이 즉시 mutation · 실패하면 원상 복귀"| RVA
        RVJ -->|"부적절"| RVX["리뷰 삭제 — ConfirmDialog intent delete<br/>클레임과 다르다: 리뷰는 지운다<br/>클레임은 감사 성격이라 삭제 라우트가 없다"]
    end

    classDef gate fill:#fef3c7,stroke:#d97706,color:#78350f
    classDef err fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
    classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d
    class KIND,CB,OFF,WG,GO,VS,IDEM,RFK,RFB,RVF,RVJ,RVQ gate
    class CBU,CBS,WG1,WG2,VSX,SKIP,NOSTK,RFN,RB1,RB2,RB3,RB4,RB5,RVX err
    class CDONE,MOVE,RACT,RREST,RVA ok
